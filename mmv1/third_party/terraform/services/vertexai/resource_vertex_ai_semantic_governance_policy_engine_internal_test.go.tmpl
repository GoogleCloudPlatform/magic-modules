package vertexai

import (
	"testing"

	"github.com/hashicorp/terraform-provider-google/google/tpgresource"
)

// Unit tests for the SemanticGovernancePolicyEngine helpers declared in
// mmv1/templates/terraform/constants/semantic_governance_policy_engine.go.tmpl
// (generated into resource_vertex_ai_semantic_governance_policy_engine.go).
//
// The CustomizeDiff tests call sgpeFailedStateWarningCheck directly
// through tpgresource.ResourceDiffMock, the established magic-modules
// pattern (precedent:
// resource_data_loss_prevention_stored_info_type_internal_test.go).
//
// The post_read tests call sgpePostReadDispatch directly: it accepts the
// minimal sgpeResourceID interface (Id/SetId), which fakeResourceData
// implements, so these tests exercise the real production switch rather
// than a copy.

// fakeResourceData implements sgpeResourceID and records SetId calls so
// tests can assert post_read clears the ID exactly once.
type fakeResourceData struct {
	id        string
	setIdArgs []string
}

func (f *fakeResourceData) Id() string     { return f.id }
func (f *fakeResourceData) SetId(v string) { f.setIdArgs = append(f.setIdArgs, v); f.id = v }

// post_read translates INACTIVE to SetId("") so the next plan re-creates.
func TestUnitSGPE_PostReadDispatch_INACTIVE_clears_id(t *testing.T) {
	t.Parallel()
	d := &fakeResourceData{id: "projects/p/locations/us-central1/semanticGovernancePolicyEngine"}
	res := map[string]interface{}{"state": "INACTIVE"}
	if err := sgpePostReadDispatch(d, res); err != nil {
		t.Fatalf("expected nil error on INACTIVE, got %v", err)
	}
	if d.Id() != "" {
		t.Errorf("expected SetId(\"\") to clear the ID; got %q", d.Id())
	}
	if len(d.setIdArgs) != 1 || d.setIdArgs[0] != "" {
		t.Errorf("expected exactly one SetId(\"\") call; got %v", d.setIdArgs)
	}
}

// post_read returns error on STATE_UNSPECIFIED, unrecognized enums, and
// missing/malformed state fields (loud-failure stance — see the
// constants template's sgpePostReadDispatch comment).
func TestUnitSGPE_PostReadDispatch_unknownStates_return_error(t *testing.T) {
	t.Parallel()
	cases := map[string]map[string]interface{}{
		"STATE_UNSPECIFIED":             {"state": "STATE_UNSPECIFIED"},
		"unrecognized future value":     {"state": "FUTURE_VALUE_NOT_YET_SUPPORTED"},
		"state field missing":           {},
		"state field is not a string":   {"state": 42},
	}
	for name, res := range cases {
		t.Run(name, func(t *testing.T) {
			d := &fakeResourceData{id: "irrelevant"}
			err := sgpePostReadDispatch(d, res)
			if err == nil {
				t.Fatalf("expected non-nil error for case %q; got nil", name)
			}
			if d.Id() == "" {
				t.Errorf("error path must NOT clear the ID; SetId(\"\") was called for case %q", name)
			}
		})
	}
}

// post_read leaves ACTIVE and FAILED states populated and in state.
// PROVISIONING and DEPROVISIONING also leave the resource in state (with
// a [WARN] log on the production path); included here for belt-and-braces.
func TestUnitSGPE_PostReadDispatch_inStateBranches_no_op(t *testing.T) {
	t.Parallel()
	for _, state := range []string{"ACTIVE", "FAILED", "PROVISIONING", "DEPROVISIONING"} {
		t.Run(state, func(t *testing.T) {
			origID := "projects/p/locations/us-central1/semanticGovernancePolicyEngine"
			d := &fakeResourceData{id: origID}
			err := sgpePostReadDispatch(d, map[string]interface{}{"state": state})
			if err != nil {
				t.Fatalf("expected nil error for state %q; got %v", state, err)
			}
			if d.Id() != origID {
				t.Errorf("state %q must NOT clear the ID; ID is now %q", state, d.Id())
			}
			if len(d.setIdArgs) != 0 {
				t.Errorf("state %q must NOT call SetId; got SetId calls %v", state, d.setIdArgs)
			}
		})
	}
}

// Plan-time CustomizeDiff Check 1 returns nil (does not block) on
// FAILED + non-empty diff. Production behavior also emits a [WARN] log;
// we don't assert log content because log capture is fragile and the
// warning visibility is TF_LOG=WARN-only by design (see the
// sgpeFailedStateWarningCheck comment in the constants template).
func TestUnitSGPE_FailedStateWarningCheck_FAILED_with_diff_succeeds(t *testing.T) {
	t.Parallel()
	d := &tpgresource.ResourceDiffMock{
		Before: map[string]interface{}{
			"state":          "FAILED",
			"target_project": "old-project",
		},
		After: map[string]interface{}{
			"state":          "FAILED",
			"target_project": "new-project",
		},
	}
	if err := sgpeFailedStateWarningCheck(d); err != nil {
		t.Fatalf("expected nil error (warnings are non-blocking); got %v", err)
	}
}

// Plan-time CustomizeDiff Check 1 does NOT fire when state ≠ FAILED OR
// diff is empty. Negative cases.
func TestUnitSGPE_FailedStateWarningCheck_negativeCases_no_op(t *testing.T) {
	t.Parallel()
	cases := map[string]*tpgresource.ResourceDiffMock{
		"ACTIVE with diff": {
			Before: map[string]interface{}{"state": "ACTIVE", "target_project": "old"},
			After:  map[string]interface{}{"state": "ACTIVE", "target_project": "new"},
		},
		"PROVISIONING with diff": {
			Before: map[string]interface{}{"state": "PROVISIONING", "target_project": "old"},
			After:  map[string]interface{}{"state": "PROVISIONING", "target_project": "new"},
		},
		"FAILED with empty diff": {
			Before: map[string]interface{}{"state": "FAILED", "target_project": "x"},
			After:  map[string]interface{}{"state": "FAILED", "target_project": "x"},
		},
	}
	for name, d := range cases {
		t.Run(name, func(t *testing.T) {
			if err := sgpeFailedStateWarningCheck(d); err != nil {
				t.Fatalf("expected nil error; got %v", err)
			}
		})
	}
}

