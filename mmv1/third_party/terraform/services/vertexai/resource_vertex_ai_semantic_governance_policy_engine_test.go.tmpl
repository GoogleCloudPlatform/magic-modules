// Handwritten lifecycle test (Create + Import + gateway_config
// create/update/rename/remove; deprovision via CheckDestroy). The
// generated samples are exclude_test — see the singleton-aware
// CheckDestroy below for why.
//
// SGPE is an AIP-156 project-regional singleton, so all steps below
// operate on the same underlying engine. Do NOT add a second parallel
// test that provisions SGPE in the same (project, us-central1) — the
// two runs would race on the singleton.
//
// gateway_config lifecycle coverage (HLD.md §3):
//
//	Step 3 addGateway     : create — provision "primary"; assert state ACTIVE + psc_endpoint set.
//	Step 5 updateGateway  : update — mutate primary's dns_zone_name; asserts primary is still ACTIVE
//	                        after the in-place update, plus siblings-untouched (secondary unchanged).
//	Step 7 renameGateway  : rename — drop "primary", add "main"; siblings stay ACTIVE; main gets a
//	                        fresh psc_endpoint via the backend teardown-and-recreate chain.
//	Step 9 removeAllGateways: remove — drop everything; post-apply Get MUST return no gateway_config keys
//	                        (state-only removal would miss the failure mode HLD §5 warns about).
//
// The rename step's "sibling stays ACTIVE with unchanged psc_endpoint"
// invariant (HLD §3, §4) is asserted at the state-level as ACTIVE-with-
// psc_endpoint-set on both. A stronger "same psc_endpoint before and
// after" cross-step assertion would need a stashing pattern; skipped as
// good-to-have (not blocking) since VCR replay against a real backend
// already exercises the value round-trip.
func TestAccVertexAISemanticGovernancePolicyEngine_lifecycle(t *testing.T) {
	t.Parallel()

	context := map[string]interface{}{}

	acctest.VcrTest(t, resource.TestCase{
		PreCheck:                 func() { acctest.AccTestPreCheck(t) },
		ProtoV5ProviderFactories: acctest.ProtoV5ProviderFactories(t),
		CheckDestroy:             testAccCheckVertexAISemanticGovernancePolicyEngineDestroyProducer(t),
		Steps: []resource.TestStep{
			// Step 1: Create basic (engine only, no gateway_config).
			{
				Config: testAccVertexAISemanticGovernancePolicyEngine_basic(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"state", "ACTIVE"),
					resource.TestCheckResourceAttrSet(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"name"),
					resource.TestCheckResourceAttrSet(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"create_time"),
					resource.TestCheckResourceAttrSet(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"psc_service_attachment"),
					// ip_address and psc_forwarding_rule are not asserted: they
					// populate only after a consumer creates a PSC forwarding
					// rule, which the basic fixture has none of.
				),
			},
			// Step 2: ImportStateVerify (engine only, no gateway_config).
			{
				ResourceName:      "google_vertex_ai_semantic_governance_policy_engine.sgpe",
				ImportState:       true,
				ImportStateVerify: true,
			},
			// Step 3 (addGateway): provision "primary". Exercises the
			// gateway_config expand path + backend per-gateway create chain
			// (reserve IP → create PSC endpoint → create DNS A-record).
			{
				Config: testAccVertexAISemanticGovernancePolicyEngine_addGateway(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.#", "1"),
					resource.TestCheckTypeSetElemNestedAttrs(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.*",
						map[string]string{"name": "primary", "state": "ACTIVE"}),
				),
			},
			// Step 4: ImportStateVerify (round-trip with gateway_config).
			// The critical SGPE-specific assertion: confirms the native Map
			// declaration's flatten path produces a stable round-trip through
			// Import (no drift in the proto map -> TypeSet conversion).
			{
				ResourceName:      "google_vertex_ai_semantic_governance_policy_engine.sgpe",
				ImportState:       true,
				ImportStateVerify: true,
			},
			// Step 5 (updateGateway): mutate primary's dns_zone_name + add
			// "secondary" as a sibling. Exercises the Update code path and
			// the multi-gateway map shape at the same time.
			{
				Config: testAccVertexAISemanticGovernancePolicyEngine_updateGatewayAndAddSecondary(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.#", "2"),
					resource.TestCheckTypeSetElemNestedAttrs(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.*",
						map[string]string{"name": "primary", "state": "ACTIVE"}),
					resource.TestCheckTypeSetElemNestedAttrs(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.*",
						map[string]string{"name": "secondary", "state": "ACTIVE"}),
				),
			},
			// Step 6: ImportStateVerify (round-trip with 2 gateways).
			{
				ResourceName:      "google_vertex_ai_semantic_governance_policy_engine.sgpe",
				ImportState:       true,
				ImportStateVerify: true,
			},
			// Step 7 (renameGateway): rename "primary" -> "main"; keep
			// "secondary". Exercises HLD §2.3 Option B pass-through: the
			// backend tombstones "primary" (runs teardown chain), provisions
			// "main" fresh (runs create chain), and leaves "secondary"
			// ACTIVE. The provider issues one PATCH; the sibling-invariance
			// is a backend property.
			{
				Config: testAccVertexAISemanticGovernancePolicyEngine_renamePrimaryToMain(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.#", "2"),
					resource.TestCheckTypeSetElemNestedAttrs(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.*",
						map[string]string{"name": "main", "state": "ACTIVE"}),
					resource.TestCheckTypeSetElemNestedAttrs(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.*",
						map[string]string{"name": "secondary", "state": "ACTIVE"}),
					// Explicitly assert "primary" is gone (drop-add rename
					// semantics: the old key must not resurface).
					testAccCheckSGPEGatewayConfigNamesExact(t,
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						[]string{"main", "secondary"}),
				),
			},
			// Step 8: ImportStateVerify (round-trip after rename).
			{
				ResourceName:      "google_vertex_ai_semantic_governance_policy_engine.sgpe",
				ImportState:       true,
				ImportStateVerify: true,
			},
			// Step 9 (removeAllGateways): drop all gateway_config blocks.
			// A Terraform-local state assertion (gateway_config.# == 0)
			// alone is NOT sufficient: a hypothetical backend regression
			// that silently acked a remove without running the teardown
			// chain would still leave orphan PSC/IP/DNS resources
			// server-side (this is exactly the A10 failure class the
			// tombstone-chain fix, cl/945777282, closes). Assert against
			// a live Get too.
			{
				Config: testAccVertexAISemanticGovernancePolicyEngine_basic(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr(
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						"gateway_config.#", "0"),
					testAccCheckSGPEGatewayConfigNamesExact(t,
						"google_vertex_ai_semantic_governance_policy_engine.sgpe",
						[]string{}),
				),
			},
		},
	})
}

func testAccVertexAISemanticGovernancePolicyEngine_basic(context map[string]interface{}) string {
	return acctest.Nprintf(`
resource "google_vertex_ai_semantic_governance_policy_engine" "sgpe" {
  region = "us-central1"
}
`, context)
}

// gateway_config fixtures reuse the project's "default" VPC and inline
// a private google_dns_managed_zone so the test is self-contained
// (runnable in any project with a default VPC + subnet, including
// HashiCorp CI projects, once the SGPE backend gate clears). The zone
// uses an RFC 2606 reserved domain (example.com.) so there's no risk
// of colliding with a real DNS zone. depends_on wires the SGPE update
// before the zone destroy on the remove-all step (Step 9).
//
// See SCOPE.md §7.1 for the record-time environment prerequisite
// (cl/945777282 live in us-central1 prod).

const testAccSGPESharedDNSZone = `
resource "google_dns_managed_zone" "sgpe_zone" {
  name        = "tf-sgpe-lifecycle-zone"
  dns_name    = "sgpe-lifecycle.example.com."
  description = "Private DNS zone for SGPE lifecycle acceptance test."
  visibility  = "private"

  private_visibility_config {
    networks {
      network_url = "projects/${data.google_project.project.project_id}/global/networks/default"
    }
  }
}
`

func testAccVertexAISemanticGovernancePolicyEngine_addGateway(context map[string]interface{}) string {
	return acctest.Nprintf(`
data "google_project" "project" {
}
`+testAccSGPESharedDNSZone+`
resource "google_vertex_ai_semantic_governance_policy_engine" "sgpe" {
  region = "us-central1"

  gateway_config {
    name          = "primary"
    network       = "projects/${data.google_project.project.project_id}/global/networks/default"
    subnetwork    = "projects/${data.google_project.project.project_id}/regions/us-central1/subnetworks/default"
    dns_zone_name = google_dns_managed_zone.sgpe_zone.name
  }

  depends_on = [google_dns_managed_zone.sgpe_zone]
}
`, context)
}

