	if v, ok := edc["maxBadRecords"].(float64); ok && v != 0 {
		result["max_bad_records"] = int64(v)
	}

	if v, ok := edc["sourceFormat"].(string); ok && v != "" {
		result["source_format"] = v
	}

	if v, ok := edc["connectionId"].(string); ok && v != "" {
