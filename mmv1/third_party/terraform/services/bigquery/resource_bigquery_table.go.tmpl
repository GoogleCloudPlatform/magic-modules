		edc["jsonExtension"] = v.(string)
	}

	if v, ok := raw["csv_options"]; ok {
		edc["csvOptions"] = expandCsvOptions(v)
	}
	if v, ok := raw["json_options"]; ok {
		edc["jsonOptions"] = expandJsonOptions(v)
	}
	if v, ok := raw["bigtable_options"]; ok {
