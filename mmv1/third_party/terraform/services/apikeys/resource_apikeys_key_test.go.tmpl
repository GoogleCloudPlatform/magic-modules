package apikeys_test

import (
	"fmt"
	"strings"
	"testing"

	"github.com/hashicorp/terraform-plugin-testing/helper/resource"
	"github.com/hashicorp/terraform-plugin-testing/terraform"

	"github.com/hashicorp/terraform-provider-google/google/acctest"
	"github.com/hashicorp/terraform-provider-google/google/services/apikeys"
	"github.com/hashicorp/terraform-provider-google/google/tpgresource"
	transport_tpg "github.com/hashicorp/terraform-provider-google/google/transport"
)

func TestAccApikeysKey_basic(t *testing.T) {
	t.Parallel()

	context := map[string]interface{}{
		"random_suffix": acctest.RandString(t, 10),
	}

	acctest.VcrTest(t, resource.TestCase{
		PreCheck:                 func() { acctest.AccTestPreCheck(t) },
		ProtoV5ProviderFactories: acctest.ProtoV5ProviderFactories(t),
		CheckDestroy:             testAccCheckApikeysKeyDestroyProducer(t),
		Steps: []resource.TestStep{
			{
				Config: testAccApikeysKey_basic(context),
			},
			{
				ResourceName:            "google_apikeys_key.primary",
				ImportState:             true,
				ImportStateVerify:       true,
				ImportStateVerifyIgnore: []string{"deletion_policy", "annotations"},
			},
			{
				Config: testAccApikeysKey_update(context),
			},
			{
				ResourceName:            "google_apikeys_key.primary",
				ImportState:             true,
				ImportStateVerify:       true,
				ImportStateVerifyIgnore: []string{"deletion_policy", "annotations"},
			},
		},
	})
}

func testAccApikeysKey_basic(context map[string]interface{}) string {
	return acctest.Nprintf(`
resource "google_apikeys_key" "primary" {
  name         = "tf-test-key%{random_suffix}"
  display_name = "sample-key"

  annotations = {
    env = "test"
  }

  restrictions {
    api_targets {
      service = "translate.googleapis.com"
      methods = ["GET*"]
    }
  }
}
`, context)
}

func testAccApikeysKey_update(context map[string]interface{}) string {
	return acctest.Nprintf(`
resource "google_apikeys_key" "primary" {
  name         = "tf-test-key%{random_suffix}"
  display_name = "sample-key-updated"

  annotations = {
    env  = "prod"
    team = "platform"
  }

  restrictions {
    api_targets {
      service = "translate.googleapis.com"
      methods = ["GET*"]
    }

    browser_key_restrictions {
      allowed_referrers = ["*.example.com"]
    }
  }
}
`, context)
}

// testAccCheckApikeysKeyDestroyProducer verifies the key is gone. API keys are soft-deleted:
// a GET keeps returning a deleted key (with a deleteTime set) until it is purged, so a key is
// considered destroyed if the GET returns a not-found error OR the returned key has a deleteTime.
func testAccCheckApikeysKeyDestroyProducer(t *testing.T) func(s *terraform.State) error {
	return func(s *terraform.State) error {
		for name, rs := range s.RootModule().Resources {
			if rs.Type != "google_apikeys_key" {
				continue
			}
			if strings.HasPrefix(name, "data.") {
				continue
			}

			config := acctest.GoogleProviderConfig(t)

			url, err := tpgresource.ReplaceVarsForTest(config, rs, transport_tpg.BaseUrl(apikeys.Product, config)+"projects/{{"{{"}}project{{"}}"}}/locations/global/keys/{{"{{"}}name{{"}}"}}")
			if err != nil {
				return err
			}

			billingProject := ""
			if config.BillingProject != "" {
				billingProject = config.BillingProject
			}

			res, err := transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
				Config:    config,
				Method:    "GET",
				Project:   billingProject,
				RawURL:    url,
				UserAgent: config.UserAgent,
			})
			if err != nil {
				// A not-found error means the key was fully removed.
				continue
			}
			if dt, ok := res["deleteTime"]; !ok || dt == nil || dt == "" {
				return fmt.Errorf("ApikeysKey still exists at %s", url)
			}
		}

		return nil
	}
}
