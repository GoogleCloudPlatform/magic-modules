func TestAccComputeOrganizationSecurityPolicyRule_organizationSecurityPolicyRuleFirewallUpdate(t *testing.T) {
	t.Parallel()

	context := map[string]interface{}{
		"org_id":        envvar.GetTestOrgFromEnv(t),
		"random_suffix": acctest.RandString(t, 10),
	}

	acctest.VcrTest(t, resource.TestCase{
		PreCheck:                 func() { acctest.AccTestPreCheck(t) },
		ProtoV5ProviderFactories: acctest.ProtoV5ProviderFactories(t),
		CheckDestroy:             testAccCheckComputeOrganizationSecurityPolicyRuleDestroyProducer(t),
		Steps: []resource.TestStep{
			{
				Config: testAccComputeOrganizationSecurityPolicyRule_organizationSecurityPolicyRuleFirewallPreUpdate(context),
			},
			{
				ResourceName:            "google_compute_organization_security_policy_rule.policy",
				ImportState:             true,
				ImportStateVerify:       true,
			},
			{
				Config: testAccComputeOrganizationSecurityPolicyRule_organizationSecurityPolicyRuleFirewallPostUpdate(context),
			},
			{
				ResourceName:            "google_compute_organization_security_policy_rule.policy",
				ImportState:             true,
				ImportStateVerify:       true,
			},
		},
	})
}

func testAccComputeOrganizationSecurityPolicyRule_organizationSecurityPolicyRuleFirewallPreUpdate(context map[string]interface{}) string {
	return acctest.Nprintf(`
resource "google_folder" "security_policy_target" {
  display_name = "tf-test-secpol-%{random_suffix}"
  parent       = "organizations/%{org_id}"
  deletion_protection = false
}

resource "google_compute_organization_security_policy" "policy" {
  display_name = "tf-test%{random_suffix}"
  short_name   = "tf-test%{random_suffix}"
  parent       = google_folder.security_policy_target.name
  type         = "CLOUD_ARMOR"
}

resource "google_compute_organization_security_policy_rule" "policy" {
  policy_id = google_compute_organization_security_policy.policy.id
  action = "deny(403)"
  description = "Block traffic from sanctioned countries"

  match {
    expr {
      expression = "origin.region_code == 'CU' || origin.region_code == 'IR'"
    }
  }
  priority = 100
}
`, context)
}

func testAccComputeOrganizationSecurityPolicyRule_organizationSecurityPolicyRuleFirewallPostUpdate(context map[string]interface{}) string {
	return acctest.Nprintf(`
