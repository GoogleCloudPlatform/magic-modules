func resourceInstancePartnerMetadata(d tpgresource.TerraformResourceData) (map[string]interface{}, error) {
	result := make(map[string]interface{})
	partnerMetadataMap := d.Get("partner_metadata").(map[string]interface{})
	for key, value := range partnerMetadataMap {
		var parsed map[string]interface{}
		if err := json.Unmarshal([]byte(value.(string)), &parsed); err != nil {
			return nil, err
		}
		result[key] = parsed
	}
	return result, nil
}

func resourceInstancePatchPartnerMetadata(d tpgresource.TerraformResourceData, currentPartnerMetadata map[string]interface{}) map[string]interface{} {
	partnerMetadata, _ := resourceInstancePartnerMetadata(d)
	for key := range currentPartnerMetadata {
		if _, ok := partnerMetadata[key]; !ok {
			partnerMetadata[key] = nil
		}
	}
	return partnerMetadata
}

func flattenPartnerMetadata(partnerMetadata map[string]interface{}) (map[string]string, error) {
	partnerMetadataMap := make(map[string]string)
	for key, value := range partnerMetadata {
		if value == nil {
			continue
		}
		jsonString, err := json.Marshal(value)
		if err != nil {
			return nil, err
		}
		partnerMetadataMap[key] = string(jsonString)
	}
	return partnerMetadataMap, nil
}

// convertPartnerMetadataToCompute builds the partner metadata as a JSON-shaped
// map[string]interface{} mirroring the compute.StructuredEntries API type (each
// value is the parsed entries object, or an empty object for nil).
func convertPartnerMetadataToCompute(pm map[string]interface{}) (map[string]interface{}, error) {
	result := make(map[string]interface{})
	for key, value := range pm {
		if value == nil {
			result[key] = map[string]interface{}{}
			continue
		}
		result[key] = value
	}
	return result, nil
}

func convertPartnerMetadataFromCompute(pm map[string]interface{}) map[string]interface{} {
	result := make(map[string]interface{})
	for key, raw := range pm {
		value, ok := raw.(map[string]interface{})
		if !ok || value == nil {
			result[key] = nil
			continue
		}
		entries, hasEntries := value["entries"]
		if !hasEntries || entries == nil {
			result[key] = nil
			continue
		}
		result[key] = value
	}
	return result
}
func ComparePartnerMetadataDiff(_, old, new string, d *schema.ResourceData) bool {
	var oldJson map[string]interface{}
	var newJson map[string]interface{}
	json.Unmarshal([]byte(old), &oldJson)
	json.Unmarshal([]byte(new), &newJson)
	if reflect.DeepEqual(oldJson, newJson) {
		return true
	}
	return false
}
