            display_name = "dummy-agent-update"
          }
        }
      }
      steps {
        expectation {
          note = "Expect mock tool response update"
          mock_tool_response {
            id = "tool-call-id-5-new"
            response = { result = "updated_mocked" }
            tool = "projects/${google_ces_app.app.project}/locations/us/apps/${google_ces_app.app.app_id}/tools/${google_ces_tool.tool.tool_id}"
          }
        }
      }
      steps {
        expectation {
          note = "Expect tool response update"
          tool_response {
            toolset_tool {
              toolset = "projects/${google_ces_app.app.project}/locations/us/apps/${google_ces_app.app.app_id}/toolsets/dummy-toolset-update"
              tool_id = "updated-dummy-tool"
            }
