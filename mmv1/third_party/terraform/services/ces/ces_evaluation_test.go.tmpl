            args = {
              param = "new_value"
            }
          }
        }
      }
      steps {
        expectation {
          note = "Expect agent response update"
          agent_response {
            role = "agent"
            chunks {
              updated_variables = { "key": "new_value" }
            }
            chunks {
              agent_transfer {
                target_agent = "projects/${google_ces_app.app.project}/locations/us/apps/${google_ces_app.app.app_id}/agents/dummy-agent-update"
              }
            }
            chunks {
              tool_call {
