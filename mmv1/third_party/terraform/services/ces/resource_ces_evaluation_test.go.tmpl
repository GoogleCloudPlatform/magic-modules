          tool_responses {
            tool_responses {
              id = "tool-call-id-6-new"
              response = { result = "updated_user_provided" }
              tool = "projects/${google_ces_app.app.project}/locations/us/apps/${google_ces_app.app.app_id}/tools/${google_ces_tool.tool.tool_id}"
            }
          }
        }
      }
      steps {
        user_input {
          event {
            event = "updated-event"
          }
        }
      }
      steps {
        user_input {
          dtmf = "5678"
        }
      }
      steps {
        user_input {
          audio = "dXBkYXRlZCBhdWRpbyBkYXRh"
        }
      }
      steps {
        user_input {
          blob {
            mime_type = "text/plain"
            data = "dXBkYXRlZCBibG9iIGRhdGE="
          }
        }
      }
      steps {
        user_input {
          image {
            mime_type = "image/png"
            data = "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg=="
          }
        }
