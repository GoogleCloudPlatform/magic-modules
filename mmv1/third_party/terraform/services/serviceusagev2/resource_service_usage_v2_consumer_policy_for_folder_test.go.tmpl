package serviceusagev2_test
{{- if ne $.TargetVersionName "ga" }}

import (
	"testing"

	"github.com/hashicorp/terraform-plugin-testing/helper/resource"

	"github.com/hashicorp/terraform-provider-google/google/acctest"
	"github.com/hashicorp/terraform-provider-google/google/envvar"
)

func TestAccServiceUsageV2ConsumerPolicyForFolder_update(t *testing.T) {
	t.Parallel()

	context := map[string]interface{}{
		"org_id":        envvar.GetTestOrgFromEnv(t),
		"random_suffix": acctest.RandString(t, 10),
	}

	acctest.VcrTest(t, resource.TestCase{
		PreCheck:                 func() { acctest.AccTestPreCheck(t) },
		ProtoV5ProviderFactories: acctest.ProtoV5ProviderBetaFactories(t),
		CheckDestroy:             testAccCheckServiceUsageV2ConsumerPolicyForFolderDestroyProducer(t),
		Steps: []resource.TestStep{
			{
				Config: testAccServiceUsageV2ConsumerPolicyForFolder_basic(context),
			},
			{
				ResourceName:            "google_service_usage_v2_consumer_policy_for_folder.default",
				ImportState:             true,
				ImportStateVerify:       true,
				ImportStateVerifyIgnore: []string{"folder", "force"},
			},
			{
				Config: testAccServiceUsageV2ConsumerPolicyForFolder_update(context),
			},
			{
				ResourceName:            "google_service_usage_v2_consumer_policy_for_folder.default",
				ImportState:             true,
				ImportStateVerify:       true,
				ImportStateVerifyIgnore: []string{"folder", "force"},
			},
			{
				Config: testAccServiceUsageV2ConsumerPolicyForFolder_removeService(context),
			},
			{
				ResourceName:            "google_service_usage_v2_consumer_policy_for_folder.default",
				ImportState:             true,
				ImportStateVerify:       true,
				ImportStateVerifyIgnore: []string{"folder", "force"},
			},
		},
	})
}

func testAccServiceUsageV2ConsumerPolicyForFolder_basic(context map[string]interface{}) string {
	return acctest.Nprintf(`
resource "google_folder" "test" {
  provider     = google-beta
  display_name = "tf-test-folder%{random_suffix}"
  parent       = "organizations/%{org_id}"
  deletion_protection = false
}

resource "google_service_usage_v2_consumer_policy_for_folder" "default" {
  provider = google-beta
  folder   = google_folder.test.folder_id

  enable_rules {
    services = [
      "services/storage.googleapis.com"
    ]
  }
}
`, context)
}

func testAccServiceUsageV2ConsumerPolicyForFolder_update(context map[string]interface{}) string {
	return acctest.Nprintf(`
resource "google_folder" "test" {
  provider     = google-beta
  display_name = "tf-test-folder%{random_suffix}"
  parent       = "organizations/%{org_id}"
  deletion_protection = false
}

resource "google_service_usage_v2_consumer_policy_for_folder" "default" {
  provider = google-beta
  folder   = google_folder.test.folder_id
  force    = true

  enable_rules {
    services = [
      "services/storage.googleapis.com",
      "services/compute.googleapis.com"
    ]
  }
}
`, context)
}

func testAccServiceUsageV2ConsumerPolicyForFolder_removeService(context map[string]interface{}) string {
	return acctest.Nprintf(`
resource "google_folder" "test" {
  provider     = google-beta
  display_name = "tf-test-folder%{random_suffix}"
  parent       = "organizations/%{org_id}"
  deletion_protection = false
}

resource "google_service_usage_v2_consumer_policy_for_folder" "default" {
  provider = google-beta
  folder   = google_folder.test.folder_id
  force    = true

  enable_rules {
    services = [
      "services/storage.googleapis.com"
    ]
  }
}
`, context)
}
{{- end }}
