package fwprovider

import (
	"github.com/hashicorp/terraform-plugin-framework/list"
	sdkprovider "github.com/hashicorp/terraform-provider-google/google/provider"
)

// iamMemberListResourcesHandwritten returns list resources for handwritten IAM member types.
func iamMemberListResourcesHandwritten() []func() list.ListResource {
	// FrameworkProvider list resources are centralized in the SDK provider registry for now.
	return []func() list.ListResource{}
}

// iamMemberListResourcesMMV1 returns list resources for MMv1-generated IAM member types.
func iamMemberListResourcesMMV1() []func() list.ListResource {
	// FrameworkProvider list resources are centralized in the SDK provider registry for now.
	return sdkprovider.IamMemberListResources()
}

// iamMemberListResources returns all list resources used by FrameworkProvider for IAM member types.
//
// Grouping note:
// - Members: handwritten, then MMv1
// - Bindings/Policies: no list resources yet in the plugin-framework registry (placeholders)
func iamMemberListResources() []func() list.ListResource {
	// FrameworkProvider list resources are centralized in the SDK provider registry for now.
	return sdkprovider.IamMemberListResources()
}
