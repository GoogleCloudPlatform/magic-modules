package converters

import (
	"strings"

	"github.com/GoogleCloudPlatform/terraform-google-conversion/v7/pkg/cai2hcl/models"
	"github.com/GoogleCloudPlatform/terraform-google-conversion/v7/pkg/caiasset"
)

func ConvertResource(assets []caiasset.Asset, options *models.Options) ([][]byte, error) {
	assetsByKey := make(map[string][]caiasset.Asset)
	converterByKey := make(map[string]models.Cai2hclConverter)

	for _, asset := range assets {
		converters, ok := ConverterMap[asset.Type]
		if !ok || len(converters) == 0 {
			continue
		}

		var converter models.Cai2hclConverter
		var alias string
		// Normally, one asset type has only one converter.
		if len(converters) == 1 {
			alias = "Default"
			converter = converters[alias]
		} else {
			// Edge cases
			// Handle the edge case that multiple Terraform resources share the same CAI asset type
			switch asset.Type {
{{- range $resourceType, $resources := $.ResourcesByCaiResourceType}}
	{{- if gt (len $resources) 1 }}
			case "{{ $resourceType }}":
		{{- if eq $resourceType "compute.googleapis.com/SslCertificate" }}
				if strings.Contains(asset.Name, "regions") {
					alias = "ComputeRegionSslCertificate"
				} else if typeVal, ok := asset.Resource.Data["type"]; ok && typeVal == "MANAGED" {
					alias = "ComputeManagedSslCertificate"
				} else {
					alias = "ComputeSslCertificate"
				}
		{{- else }}
		{{- range $i, $object := $resources }}
			{{- if eq $i 0 }}
				if true {{- range $param := $object.IdentityParams }} && strings.Contains(asset.Name, "{{$param}}"){{- end }} {
					alias = "{{ $object.AliasName }}"
			{{- else }}
				} else if true {{- range $param := $object.IdentityParams }} && strings.Contains(asset.Name, "{{$param}}"){{- end }} {
					alias = "{{ $object.AliasName }}"
			{{- end }}
			{{- if eq $i (sub (len $resources) 1)}}
				}
			{{- end }}
		{{- end }}
		{{- end }}
				converter = converters[alias]
	{{- end }}
{{- end }}
			}
		}

		if converter != nil {
			key := asset.Type + "/" + alias
			assetsByKey[key] = append(assetsByKey[key], asset)
			converterByKey[key] = converter
		}
	}

	var allResourceBytes [][]byte
	for key, groupAssets := range assetsByKey {
		converter := converterByKey[key]
		newBlocks, err := converter.Convert(groupAssets, options)
		if err != nil {
			return nil, err
		}
		if len(newBlocks) > 0 {
			resBytes, err := models.HclWriteBlocks(newBlocks)
			if err != nil {
				return nil, err
			}
			allResourceBytes = append(allResourceBytes, resBytes)
		}
	}

	return allResourceBytes, nil
}
