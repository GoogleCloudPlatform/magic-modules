// Custom decoder for Cloud Run V2 Job to map v1 CAI asset payload (spec.template...)
// to the Terraform v2 schema structure expected by autogenerated flatteners.
if res == nil {
	return res, hclData, nil
}

// Check if top-level labels/annotations need to be pulled from metadata
if meta, ok := res["metadata"].(map[string]interface{}); ok {
	if labels, ok := meta["labels"]; ok && res["labels"] == nil {
		res["labels"] = labels
	}
	if annotations, ok := meta["annotations"]; ok && res["annotations"] == nil {
		res["annotations"] = annotations
	}
	if annotationsMap, ok := meta["annotations"].(map[string]interface{}); ok {
		if client, ok := annotationsMap["run.googleapis.com/client-name"]; ok && res["client"] == nil {
			res["client"] = client
		}
		if clientVer, ok := annotationsMap["run.googleapis.com/client-version"]; ok && res["clientVersion"] == nil {
			res["clientVersion"] = clientVer
		}
		if launchStage, ok := annotationsMap["run.googleapis.com/launch-stage"]; ok && res["launchStage"] == nil {
			res["launchStage"] = launchStage
		}
		if bg, ok := annotationsMap["run.googleapis.com/binary-authorization-breakglass"].(string); ok && bg != "" {
			if res["binaryAuthorization"] == nil {
				res["binaryAuthorization"] = make(map[string]interface{})
			}
			if binAuth, ok := res["binaryAuthorization"].(map[string]interface{}); ok {
				binAuth["breakglassJustification"] = bg
			}
		}
		if policy, ok := annotationsMap["run.googleapis.com/binary-authorization"].(string); ok && policy == "default" {
			if res["binaryAuthorization"] == nil {
				res["binaryAuthorization"] = make(map[string]interface{})
			}
			if binAuth, ok := res["binaryAuthorization"].(map[string]interface{}); ok {
				binAuth["useDefault"] = true
			}
		}
	}
}

// Map spec.template (v1 execution template) to root template (v2)
if spec, ok := res["spec"].(map[string]interface{}); ok {
	if binAuth, ok := spec["binaryAuthorization"]; ok && res["binaryAuthorization"] == nil {
		res["binaryAuthorization"] = binAuth
	}
	if execTmpl, ok := spec["template"].(map[string]interface{}); ok {
		v2Tmpl := make(map[string]interface{})
		if execMeta, ok := execTmpl["metadata"].(map[string]interface{}); ok {
			if labels, ok := execMeta["labels"]; ok {
				v2Tmpl["labels"] = labels
			}
			if annotations, ok := execMeta["annotations"]; ok {
				v2Tmpl["annotations"] = annotations
			}
		}
		if execSpec, ok := execTmpl["spec"].(map[string]interface{}); ok {
			if parallelism, ok := execSpec["parallelism"]; ok {
				v2Tmpl["parallelism"] = parallelism
			}
			if taskCount, ok := execSpec["taskCount"]; ok {
				v2Tmpl["taskCount"] = taskCount
			}
			if taskTmpl, ok := execSpec["template"].(map[string]interface{}); ok {
				v2TaskTmpl := make(map[string]interface{})
				var execAnnotations map[string]interface{}
				if execMeta, ok := execTmpl["metadata"].(map[string]interface{}); ok {
					if annotations, ok := execMeta["annotations"].(map[string]interface{}); ok {
						execAnnotations = annotations
						if execEnv, ok := annotations["run.googleapis.com/execution-environment"].(string); ok {
							if execEnv == "gen2" {
								v2TaskTmpl["executionEnvironment"] = "EXECUTION_ENVIRONMENT_GEN2"
							} else if execEnv == "gen1" {
								v2TaskTmpl["executionEnvironment"] = "EXECUTION_ENVIRONMENT_GEN1"
							} else {
								v2TaskTmpl["executionEnvironment"] = execEnv
							}
						}
					}
				}
				if taskSpec, ok := taskTmpl["spec"].(map[string]interface{}); ok {
					if rawContainers, ok := taskSpec["containers"].([]interface{}); ok {
						var v2Containers []interface{}
						for _, rc := range rawContainers {
							if cMap, ok := rc.(map[string]interface{}); ok {
								v2C := make(map[string]interface{})
								for k, v := range cMap {
									v2C[k] = v
								}
								if rawEnvs, ok := cMap["env"].([]interface{}); ok {
									var v2Envs []interface{}
									for _, re := range rawEnvs {
										if eMap, ok := re.(map[string]interface{}); ok {
											v2E := make(map[string]interface{})
											for k, v := range eMap {
												v2E[k] = v
											}
											if vf, ok := eMap["valueFrom"].(map[string]interface{}); ok && v2E["valueSource"] == nil {
												vs := make(map[string]interface{})
												if skr, ok := vf["secretKeyRef"].(map[string]interface{}); ok {
													v2Skr := make(map[string]interface{})
													if name, ok := skr["name"]; ok { v2Skr["secret"] = name }
													if sec, ok := skr["secret"]; ok { v2Skr["secret"] = sec }
													if ver, ok := skr["version"]; ok { v2Skr["version"] = ver }
													if key, ok := skr["key"]; ok { v2Skr["version"] = key }
													if len(v2Skr) > 0 { vs["secretKeyRef"] = v2Skr }
												}
												if len(vs) > 0 { v2E["valueSource"] = vs }
											}
											v2Envs = append(v2Envs, v2E)
										} else {
											v2Envs = append(v2Envs, re)
										}
									}
									v2C["env"] = v2Envs
								}
								v2Containers = append(v2Containers, v2C)
							} else {
								v2Containers = append(v2Containers, rc)
							}
						}
						v2TaskTmpl["containers"] = v2Containers
					}
					if rawVols, ok := taskSpec["volumes"].([]interface{}); ok {
						var v2Vols []interface{}
						for _, rv := range rawVols {
							if volMap, ok := rv.(map[string]interface{}); ok {
								v2Vol := make(map[string]interface{})
								for k, v := range volMap {
									v2Vol[k] = v
								}
								if csi, ok := volMap["csi"].(map[string]interface{}); ok && v2Vol["gcs"] == nil {
									if driver, ok := csi["driver"].(string); ok && driver == "gcsfuse.run.googleapis.com" {
										gcs := make(map[string]interface{})
										if ro, ok := csi["readOnly"]; ok {
											gcs["readOnly"] = ro
										}
										if attrs, ok := csi["volumeAttributes"].(map[string]interface{}); ok {
											if bucket, ok := attrs["bucketName"]; ok {
												gcs["bucket"] = bucket
											}
											if mo, ok := attrs["mountOptions"].(string); ok && mo != "" {
												parts := strings.Split(mo, ",")
												var moList []interface{}
												for _, p := range parts {
													if trimmed := strings.TrimSpace(p); trimmed != "" {
														moList = append(moList, trimmed)
													}
												}
												if len(moList) > 0 {
													gcs["mountOptions"] = moList
												}
											}
										}
										v2Vol["gcs"] = gcs
									}
								}
								if ed, ok := volMap["emptyDir"].(map[string]interface{}); ok {
									if med, ok := ed["medium"].(string); ok {
										if strings.EqualFold(med, "memory") {
											ed["medium"] = "MEMORY"
										} else if strings.EqualFold(med, "disk") {
											ed["medium"] = "DISK"
										} else if strings.ToUpper(med) == "MEMORY" || strings.ToUpper(med) == "DISK" {
											ed["medium"] = strings.ToUpper(med)
										}
									}
									v2Vol["emptyDir"] = ed
								}
								v2Vols = append(v2Vols, v2Vol)
							} else {
								v2Vols = append(v2Vols, rv)
							}
						}
						v2TaskTmpl["volumes"] = v2Vols
					}
					if timeoutVal, ok := taskSpec["timeoutSeconds"]; ok {
						if timeoutStr, ok := timeoutVal.(string); ok {
							if !strings.HasSuffix(timeoutStr, "s") {
								v2TaskTmpl["timeout"] = timeoutStr + "s"
							} else {
								v2TaskTmpl["timeout"] = timeoutStr
							}
						} else if timeoutNum, ok := timeoutVal.(float64); ok {
							v2TaskTmpl["timeout"] = fmt.Sprintf("%ds", int(timeoutNum))
						} else if timeoutInt, ok := timeoutVal.(int); ok {
							v2TaskTmpl["timeout"] = fmt.Sprintf("%ds", timeoutInt)
						} else {
							v2TaskTmpl["timeout"] = timeoutVal
						}
					}
					if sa, ok := taskSpec["serviceAccountName"]; ok {
						v2TaskTmpl["serviceAccount"] = sa
					}
					if retries, ok := taskSpec["maxRetries"]; ok {
						v2TaskTmpl["maxRetries"] = retries
					}
					vpc := make(map[string]interface{})
					if existingVpc, ok := taskSpec["vpcAccess"].(map[string]interface{}); ok {
						for k, v := range existingVpc {
							vpc[k] = v
						}
					}
					if execAnnotations != nil {
						if connector, ok := execAnnotations["run.googleapis.com/vpc-access-connector"].(string); ok && connector != "" {
							vpc["connector"] = connector
						}
						if egress, ok := execAnnotations["run.googleapis.com/vpc-access-egress"].(string); ok && egress != "" {
							vpc["egress"] = egress
						}
						if niStr, ok := execAnnotations["run.googleapis.com/network-interfaces"].(string); ok && niStr != "" {
							var nis []map[string]interface{}
							if err := json.Unmarshal([]byte(niStr), &nis); err == nil {
								var v2Nis []interface{}
								for _, ni := range nis {
									v2Ni := make(map[string]interface{})
									if net, ok := ni["network"]; ok { v2Ni["network"] = net }
									if subnet, ok := ni["subnetwork"]; ok { v2Ni["subnetwork"] = subnet }
									if tags, ok := ni["tags"]; ok { v2Ni["tags"] = tags }
									v2Nis = append(v2Nis, v2Ni)
								}
								if len(v2Nis) > 0 {
									vpc["networkInterfaces"] = v2Nis
								}
							}
						}
					}
					if eg, ok := vpc["egress"].(string); ok && eg != "" {
						if strings.EqualFold(eg, "all-traffic") || strings.EqualFold(eg, "all_traffic") {
							vpc["egress"] = "ALL_TRAFFIC"
						} else if strings.EqualFold(eg, "private-ranges-only") || strings.EqualFold(eg, "private_ranges_only") {
							vpc["egress"] = "PRIVATE_RANGES_ONLY"
						} else {
							vpc["egress"] = strings.ToUpper(strings.ReplaceAll(eg, "-", "_"))
						}
					}
					var sqlInstsStr string
					if execAnnotations != nil {
						if s, ok := execAnnotations["run.googleapis.com/cloudsql-instances"].(string); ok {
							sqlInstsStr = s
						}
					}
					if sqlInstsStr == "" {
						if topMeta, ok := res["metadata"].(map[string]interface{}); ok {
							if ann, ok := topMeta["annotations"].(map[string]interface{}); ok {
								if s, ok := ann["run.googleapis.com/cloudsql-instances"].(string); ok {
									sqlInstsStr = s
								}
							}
						}
					}
					if sqlInstsStr != "" {
						parts := strings.Split(sqlInstsStr, ",")
						var instList []interface{}
						for _, p := range parts {
							if trimmed := strings.TrimSpace(p); trimmed != "" {
								instList = append(instList, trimmed)
							}
						}
						if len(instList) > 0 {
							hasSqlVol := false
							if vols, ok := v2TaskTmpl["volumes"].([]interface{}); ok {
								for _, v := range vols {
									if vMap, ok := v.(map[string]interface{}); ok {
										if name, ok := vMap["name"].(string); ok && name == "cloudsql" {
											hasSqlVol = true
											break
										}
									}
								}
							}
							if !hasSqlVol {
								sqlVol := map[string]interface{}{
									"name": "cloudsql",
									"cloudSqlInstance": map[string]interface{}{
										"instances": instList,
									},
								}
								if vols, ok := v2TaskTmpl["volumes"].([]interface{}); ok {
									v2TaskTmpl["volumes"] = append(vols, sqlVol)
								} else {
									v2TaskTmpl["volumes"] = []interface{}{sqlVol}
								}
							}
							if cs, ok := v2TaskTmpl["containers"].([]interface{}); ok {
								for i, c := range cs {
									if cMap, ok := c.(map[string]interface{}); ok {
										hasSqlMount := false
										if vms, ok := cMap["volumeMounts"].([]interface{}); ok {
											for _, vm := range vms {
												if vmMap, ok := vm.(map[string]interface{}); ok {
													if name, ok := vmMap["name"].(string); ok && name == "cloudsql" {
														hasSqlMount = true
														break
													}
												}
											}
										}
										if !hasSqlMount {
											sqlMount := map[string]interface{}{
												"name": "cloudsql",
												"mountPath": "/cloudsql",
											}
											if vms, ok := cMap["volumeMounts"].([]interface{}); ok {
												cMap["volumeMounts"] = append(vms, sqlMount)
											} else {
												cMap["volumeMounts"] = []interface{}{sqlMount}
											}
										}
										cs[i] = cMap
									}
								}
								v2TaskTmpl["containers"] = cs
							}
						}
					}
					if len(vpc) > 0 {
						v2TaskTmpl["vpcAccess"] = vpc
					}
					if ns, ok := taskSpec["nodeSelector"]; ok {
						v2TaskTmpl["nodeSelector"] = ns
					}
					if ek, ok := taskSpec["encryptionKey"]; ok {
						v2TaskTmpl["encryptionKey"] = ek
					}
					if gpu, ok := taskSpec["gpuZonalRedundancyDisabled"]; ok {
						v2TaskTmpl["gpuZonalRedundancyDisabled"] = gpu
					}
				}
				v2Tmpl["template"] = v2TaskTmpl
			}
		}
		res["template"] = v2Tmpl
	}
}

return res, hclData, nil
