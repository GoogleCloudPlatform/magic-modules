	d.Set("egress_from", flattenedEgressFrom)
}
if egressToVal, ok := obj["egressTo"]; ok {
	flattenedEgressTo := flattenNestedAccessContextManagerServicePerimeterEgressPolicyEgressTo(egressToVal, d, config)
	d.Set("egress_to", flattenedEgressTo)
}
