project, err := tpgresource.GetProject(d, config)
if err != nil {
return fmt.Errorf("Error fetching project for ConsumerPolicy: %s", err)
}

obj := make(map[string]interface{})
obj["enableRules"] = []interface{}{}

url, err := tpgresource.ReplaceVars(d, config, "{{"{{"}}ServiceUsageV2BasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/consumerPolicies/default")
if err != nil {
return err
}

log.Printf("[DEBUG] Emptying ConsumerPolicy %q: %#v", d.Id(), obj)

// Add force parameter to allow destructive policy changes
url, err = transport_tpg.AddQueryParams(url, map[string]string{"force": "true"})
if err != nil {
return err
}

res, err := transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
Config:    config,
Method:    "PATCH",
Project:   project,
RawURL:    url,
UserAgent: userAgent,
Body:      obj,
Timeout:   d.Timeout(schema.TimeoutDelete),
})

if err != nil {
return fmt.Errorf("Error emptying ConsumerPolicy %q: %s", d.Id(), err)
}

err = ServiceUsageV2OperationWaitTime(
config, res, project, "Deleting ConsumerPolicy", userAgent,
d.Timeout(schema.TimeoutDelete))

if err != nil {
return err
}

log.Printf("[DEBUG] Finished emptying ConsumerPolicy %q: %#v", d.Id(), res)

return nil
