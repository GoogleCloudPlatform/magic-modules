// Poll the scope's GET endpoint until state is ACTIVE instead of polling
// the LRO, because the LRO endpoint does not support base_url_override
// (AAD serves on aiplatform.{{region}}.rep.googleapis.com, not the standard
// Vertex AI endpoint).
if err := resource.Retry(d.Timeout(schema.TimeoutCreate), func() *resource.RetryError {
	readUrl, err := tpgresource.ReplaceVars(d, config, "{{$.BaseUrlOverride}}"+"{{$.SelfLinkUri}}")
	if err != nil {
		return resource.NonRetryableError(err)
	}
	readRes, err := transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
		Config:    config,
		Method:    "GET",
		Project:   billingProject,
		RawURL:    readUrl,
		UserAgent: userAgent,
	})
	if err != nil {
		return resource.RetryableError(fmt.Errorf("error polling for scope state: %s", err))
	}
	state, ok := readRes["state"].(string)
	if !ok {
		return resource.RetryableError(fmt.Errorf("scope state not found in response"))
	}
	switch state {
	case "ACTIVE":
		log.Printf("[DEBUG] AgentAnomalyDetectionScope reached ACTIVE state")
		return nil
	case "CREATING":
		return resource.RetryableError(fmt.Errorf("scope still in CREATING state"))
	default:
		return resource.NonRetryableError(fmt.Errorf("scope reached unexpected state: %s", state))
	}
}); err != nil {
	return fmt.Errorf("error waiting for AgentAnomalyDetectionScope to become ACTIVE: %s", err)
}
