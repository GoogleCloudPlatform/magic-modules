// Handle standard attribute updates
if d.HasChangeExcept("state") {
	if err := resourceDatabaseMigrationServiceMigrationJobUpdate(d, meta); err != nil {
		return err
	}
}

// Handle State Transitions
if d.HasChange("state") {
	oldRaw, newRaw := d.GetChange("state")
	oldState := oldRaw.(string)
	newState := newRaw.(string)

	if oldState == "RUNNING" && newState == "NOT_STARTED" {
		return fmt.Errorf("Transition from RUNNING to NOT_STARTED is not supported. Please destroy and recreate the Migration Job if you need to reset it.")
	}

	if (oldState == "NOT_STARTED" || oldState == "") && newState == "RUNNING" {
		log.Printf("[DEBUG] Transitioning Migration Job %q to RUNNING", d.Id())
		url, err := tpgresource.ReplaceVars(d, config, "{{"{{"}}DatabaseMigrationServiceBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/locations/{{"{{"}}location{{"}}"}}/migrationJobs/{{"{{"}}migration_job_id{{"}}"}}:start")
		if err != nil {
			return err
		}

		userAgent, err := tpgresource.GenerateUserAgentString(d, config.UserAgent)
		if err != nil {
			return err
		}

		res, err := transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
			Config:    config,
			Method:    "POST",
			RawURL:    url,
			UserAgent: userAgent,
			Timeout:   d.Timeout(schema.TimeoutUpdate),
		})
		if err != nil {
			return fmt.Errorf("Error starting Migration Job %q during update: %s", d.Id(), err)
		}

		err = databasemigrationservice.DatabaseMigrationServiceOperationWaitTime(
			config, res, "Starting Migration Job Update", userAgent, d.Timeout(schema.TimeoutUpdate))

		if err != nil {
			return fmt.Errorf("Error waiting for Start Migration Job update operation: %s", err)
		}
	}
}

return resourceDatabaseMigrationServiceMigrationJobRead(d, meta)
