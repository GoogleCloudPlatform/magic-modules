// 2. Handle Enable/Disable Transitions (POST)
// If the 'enabled' boolean changed, call the appropriate custom RPC.
if d.HasChange("enabled") {
	_, newEnabled := d.GetChange("enabled")
	var action string
	if newEnabled.(bool) {
		action = ":enable"
	} else {
		action = ":disable"
	}

	url, err := tpgresource.ReplaceVars(d, config, "{{"{{"}}ChronicleBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/locations/{{"{{"}}location{{"}}"}}/instances/{{"{{"}}instance{{"}}"}}/feeds/{{"{{"}}feed{{"}}"}}"+action)
	if err != nil {
