userAgent, err := tpgresource.GenerateUserAgentString(d, config.UserAgent)
if err != nil {
	return err
}

project, err := tpgresource.GetProject(d, config)
if err != nil {
	return err
}

// 1. Handle Display Name Update
if d.HasChange("display_name") {
	url, err := tpgresource.ReplaceVars(d, config, "{{"{{"}}ChronicleBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/locations/{{"{{"}}location{{"}}"}}/instances/{{"{{"}}instance{{"}}"}}/feeds/{{"{{"}}feed{{"}}"}}?updateMask=display_name")
	if err != nil {
		return err
	}

	displayNamePayload := map[string]interface{}{
		"name":        d.Get("name"),
		"displayName": d.Get("display_name"),
	}

	_, err = transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
		Config:    config,
		Method:    "PATCH",
		Project:   project,
		RawURL:    url,
		UserAgent: userAgent,
		Body:      displayNamePayload,
		Timeout:   d.Timeout(schema.TimeoutUpdate),
	})
	if err != nil {
		return fmt.Errorf("Error updating Feed Display Name: %s", err)
	}
}

// 2. Handle Details Update
if d.HasChange("details") {
	url, err := tpgresource.ReplaceVars(d, config, "{{"{{"}}ChronicleBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/locations/{{"{{"}}location{{"}}"}}/instances/{{"{{"}}instance{{"}}"}}/feeds/{{"{{"}}feed{{"}}"}}?updateMask=details")
	if err != nil {
		return err
	}

	expandedDetails, err := expandChronicleFeedDetails(d.Get("details"), d, config)
	if err != nil {
		return err
	}

	detailsPayload := map[string]interface{}{
		"name":    d.Get("name"),
		"details": expandedDetails,
	}

	_, err = transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
		Config:    config,
		Method:    "PATCH",
		Project:   project,
		RawURL:    url,
		UserAgent: userAgent,
		Body:      detailsPayload,
		Timeout:   d.Timeout(schema.TimeoutUpdate),
	})
	if err != nil {
		return fmt.Errorf("Error updating Feed Details: %s", err)
	}
}

// 3. Handle Enable/Disable
if d.HasChange("enabled") {
	_, newEnabled := d.GetChange("enabled")
	var url string

	if newEnabled.(bool) {
		url, err = tpgresource.ReplaceVars(d, config, "{{"{{"}}ChronicleBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/locations/{{"{{"}}location{{"}}"}}/instances/{{"{{"}}instance{{"}}"}}/feeds/{{"{{"}}feed{{"}}"}}:enable")
	} else {
		url, err = tpgresource.ReplaceVars(d, config, "{{"{{"}}ChronicleBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/locations/{{"{{"}}location{{"}}"}}/instances/{{"{{"}}instance{{"}}"}}/feeds/{{"{{"}}feed{{"}}"}}:disable")
	}

	if err != nil {
		return err
	}

	_, err = transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
		Config:    config,
		Method:    "POST",
		Project:   project,
		RawURL:    url,
		UserAgent: userAgent,
		Body:      nil,
		Timeout:   d.Timeout(schema.TimeoutUpdate),
	})
	if err != nil {
		return fmt.Errorf("Error changing Feed state: %s", err)
	}
}

return resourceChronicleFeedRead(d, meta)
