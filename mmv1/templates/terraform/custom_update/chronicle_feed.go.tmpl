	}
	if d.HasChange("details") {
		updateMask = append(updateMask, "details")
	}

	url, err := tpgresource.ReplaceVars(d, config, "{{"{{"}}ChronicleBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/locations/{{"{{"}}location{{"}}"}}/instances/{{"{{"}}instance{{"}}"}}/feeds/{{"{{"}}feed{{"}}"}}")
	if err != nil {
		return err
	}
	url, err = transport_tpg.AddQueryParams(url, map[string]string{"updateMask": strings.Join(updateMask, ",")})
	if err != nil {
		return err
	}

	// Construct the payload
	expandedDetails, err := expandChronicleFeedDetails(d.Get("details"), d, config)
	if err != nil {
		return err
	}

	payload := map[string]interface{}{
