userAgent, err := tpgresource.GenerateUserAgentString(d, config.UserAgent)
if err != nil {
	return err
}

billingProject := ""
project, err := tpgresource.GetProject(d, config)
if err != nil {
	return fmt.Errorf("Error fetching project for Configuration: %s", err)
}
billingProject = project
if bp, err := tpgresource.GetBillingProject(d, config); err == nil {
	billingProject = bp
}

// 1. Handle standard updates (license_count) via PATCH
if d.HasChange("licenseCount") {
	obj := make(map[string]interface{})

	productProp, err := expandLicenseManagerConfigurationProduct(d.Get("product"), d, config)
	if err == nil {
		obj["product"] = productProp
	}

	licenseCountProp, err := expandLicenseManagerConfigurationLicenseCount(d.Get("licenseCount"), d, config)
	if err == nil {
		obj["licenseCount"] = licenseCountProp
	}

	// Run encoder to convert flat schema to API structure (nesting count)
	obj, err = resourceLicenseManagerConfigurationEncoder(d, meta, obj)
	if err != nil {
		return err
	}

	url, err := tpgresource.ReplaceVars(d, config, "{{ "{{" }}LicenseManagerBasePath{{ "}}" }}projects/{{ "{{" }}project{{ "}}" }}/locations/{{ "{{" }}location{{ "}}" }}/configurations/{{ "{{" }}configuration_id{{ "}}" }}")
	if err != nil {
		return err
	}

	updateMask := []string{"currentBillingInfo", "nextBillingInfo"}

	url, err = transport_tpg.AddQueryParams(url, map[string]string{"updateMask": strings.Join(updateMask, ",")})
	if err != nil {
		return err
	}

	res, err := transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
		Config:    config,
		Method:    "PATCH",
		Project:   billingProject,
		RawURL:    url,
		UserAgent: userAgent,
		Body:      obj,
		Timeout:   d.Timeout(schema.TimeoutUpdate),
	})
	if err != nil {
		return fmt.Errorf("Error updating Configuration %q: %s", d.Id(), err)
	}

	err = LicenseManagerOperationWaitTime(config, res, project, "Updating Configuration", userAgent, d.Timeout(schema.TimeoutUpdate))
	if err != nil {
		return err
	}
}

// 2. Handle state transitions (active/deactivate) via POST
if d.HasChange("active") {
	_, newActive := d.GetChange("active")
	isActive := newActive.(bool)

	var action string
	if isActive {
		action = "reactivate"
	} else {
		action = "deactivate"
	}

	url, err := tpgresource.ReplaceVars(d, config, "{{ "{{" }}LicenseManagerBasePath{{ "}}" }}projects/{{ "{{" }}project{{ "}}" }}/locations/{{ "{{" }}location{{ "}}" }}/configurations/{{ "{{" }}configuration_id{{ "}}" }}:"+action)
	if err != nil {
		return err
	}

	obj := make(map[string]interface{})

	res, err := transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
		Config:    config,
		Method:    "POST",
		Project:   billingProject,
		RawURL:    url,
		UserAgent: userAgent,
		Body:      obj,
		Timeout:   d.Timeout(schema.TimeoutUpdate),
	})
	if err != nil {
		return fmt.Errorf("Error %s Configuration %q: %s", action, d.Id(), err)
	}

	err = LicenseManagerOperationWaitTime(config, res, project, fmt.Sprintf("%s Configuration", strings.Title(action)), userAgent, d.Timeout(schema.TimeoutUpdate))
	if err != nil {
		return err
	}
}
return resourceLicenseManagerConfigurationRead(d, meta)
