resource "google_kms_autokey_config" "{{$.PrimaryResourceId}}" {
  provider    = google-beta
  folder      = "folders/${var.folder_id}"
  key_project = "projects/${var.key_project_id}"
  key_project_resolution_mode = "DEDICATED_KEY_PROJECT"
}

variable "folder_id" {
  type = string
}

variable "key_project_id" {
  type = string
}
