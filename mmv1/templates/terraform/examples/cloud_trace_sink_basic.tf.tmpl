data "google_project" "project" {
  provider = google-beta
}

resource "google_bigquery_dataset" "example" {
  provider   = google-beta
  dataset_id = "{{index $.Vars "dataset_id"}}"
  location   = "US"
}

resource "google_cloud_trace_sink" "{{$.PrimaryResourceId}}" {
  provider = google-beta

  # The Cloud Trace API references the project by its number, not its project ID,
  # both for the sink itself and for the BigQuery destination.
  project = data.google_project.project.number
  sink_id = "{{index $.Vars "sink_name"}}"

  output_config {
    destination = "bigquery.googleapis.com/projects/${data.google_project.project.number}/datasets/${google_bigquery_dataset.example.dataset_id}"
  }
}
