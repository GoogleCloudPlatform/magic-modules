resource "google_bigquery_reservation" "{{$.PrimaryResourceId}}" {
  name              = "{{index $.Vars "name"}}"
  location          = "us-west2"
  slot_capacity     = 0
  edition           = "ENTERPRISE"
  reservation_group = "projects/{{index $.TestEnvVars "project_id"}}/locations/us-west2/reservationGroups/my-group"
}
