resource "google_model_armor_template" "template-filter-config" {
  location    = "{{index $.Vars "location"}}"
  template_id = "{{index $.Vars "templateId"}}"

  filter_config {
    rai_settings {
      rai_filters {
        filter_type      = "{{index $.Vars "filter_config_rai_settings_rai_filters_0_filter_type"}}"
        confidence_level = "{{index $.Vars "filter_config_rai_settings_rai_filters_0_confidence_level"}}"
      }
    }
    sdp_settings {
      basic_config {
          filter_enforcement = "{{index $.Vars "filter_config_sdp_settings_basic_config_filter_enforcement"}}"
      }
    }
    pi_and_jailbreak_filter_settings {
      filter_enforcement = "{{index $.Vars "filter_config_pi_and_jailbreak_filter_settings_filter_enforcement"}}"
      confidence_level   = "{{index $.Vars "filter_config_pi_and_jailbreak_filter_settings_confidence_level"}}"
    }
    malicious_uri_filter_settings {
      filter_enforcement = "{{index $.Vars "filter_config_malicious_uri_filter_settings_filter_enforcement"}}"
    }
  }
  template_metadata {
    multi_language_detection {
    enable_multi_language_detection        = {{index $.Vars "template_metadata_multi_language_detection_enable_multi_language_detection"}}
    }
  }
}