resource "google_network_services_agent_gateway" "{{$.PrimaryResourceId}}" {
  name     = "{{index $.Vars "name"}}"
  location = "us-central1"

  google_managed {
    governed_access_path = "CLIENT_TO_AGENT"
  }

  registries = [
    "//agentregistry.googleapis.com/projects/{{index $.TestEnvVars "project"}}/locations/us-central1"
  ]

  depends_on = [google_project_service.agent_registry]
}

resource "google_project_service" "agent_registry" {
  service            = "agentregistry.googleapis.com"
  disable_on_destroy = false
}
