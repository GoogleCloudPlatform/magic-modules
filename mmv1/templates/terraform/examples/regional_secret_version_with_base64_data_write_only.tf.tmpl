resource "google_secret_manager_regional_secret" "secret-basic-write-only-base64" {
  secret_id = "{{index $.Vars "secret_id"}}"
  location  = "us-central1"
}

resource "google_secret_manager_regional_secret_version" "{{$.PrimaryResourceId}}" {
  secret                 = google_secret_manager_regional_secret.secret-basic-write-only-base64.id
  is_secret_data_base64  = true
  secret_data_wo_version = 1
  secret_data_wo         = filebase64("{{index $.Vars "data"}}")
}
