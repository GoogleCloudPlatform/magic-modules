resource "google_chronicle_findings_refinement" "{{$.PrimaryResourceId}}" {
  provider = google-beta
  location = "us"
  instance = "{{index $.TestEnvVars "chronicle_id"}}"
  display_name = "{{index $.Vars "display_name"}}" 
  type = "DETECTION_EXCLUSION" 
  query = "network.dns.response = true" 
  outcome_filters {
    outcome_variable = "risk_score"
    outcome_filter_operator = "EQUAL"
    outcome_value = "value"
  }
}

output "findings_refinement_create_time" {
  description = "The creation time of the findings refinement."
  value = google_chronicle_findings_refinement.example.create_time
}

output "findings_refinement_update_time" {
  description = "The last update time of the findings refinement."
  value = google_chronicle_findings_refinement.example.update_time  
} 
