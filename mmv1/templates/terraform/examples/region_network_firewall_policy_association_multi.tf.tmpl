resource "google_compute_region_network_firewall_policy" "policy1" {
  provider = google-beta
  name = "{{index $.Vars "policy_name"}}-1"
  project = "{{index $.TestEnvVars "project_name"}}"
  description = "Sample global network firewall policy"
  region = "{{index $.TestEnvVars "region"}}"
}

resource "google_compute_region_network_firewall_policy" "policy2" {
  provider = google-beta
  name = "{{index $.Vars "policy_name"}}-2"
  project = "{{index $.TestEnvVars "project_name"}}"
  description = "Sample global network firewall policy"
  region = "{{index $.TestEnvVars "region"}}"
}

resource "google_compute_network" "network" {
  provider = google-beta
  name = "{{index $.Vars "network_name"}}"
  auto_create_subnetworks = false
}

resource "google_compute_region_network_firewall_policy_association" "{{$.PrimaryResourceId}}-1" {
  provider = google-beta
  name = "{{index $.Vars "association_name"}}-1"
  project = "{{index $.TestEnvVars "project_name"}}"
  attachment_target = google_compute_network.network.id
  firewall_policy =  google_compute_region_network_firewall_policy.policy1.id
  region = "{{index $.TestEnvVars "region"}}"
  priority = 1
}

resource "google_compute_region_network_firewall_policy_association" "{{$.PrimaryResourceId}}-2" {
  provider = google-beta
  name = "{{index $.Vars "association_name"}}-2"
  project = "{{index $.TestEnvVars "project_name"}}"
  attachment_target = google_compute_network.network.id
  firewall_policy =  google_compute_region_network_firewall_policy.policy2.id
  region = "{{index $.TestEnvVars "region"}}"
  priority = 2
}
