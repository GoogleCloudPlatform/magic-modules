resource "google_model_armor_template" "template-label-advanced-config" {
  location    = "{{index $.Vars "location"}}"
  template_id = "{{index $.Vars "templateId"}}"

  labels = {
    "test-label" = "{{index $.Vars "label_test_label"}}"
  }

  filter_config {
    rai_settings {
      rai_filters {
        filter_type      = "{{index $.Vars "filter_config_rai_settings_rai_filters_0_filter_type"}}"
        confidence_level = "{{index $.Vars "filter_config_rai_settings_rai_filters_0_confidence_level"}}"
      }
    }
    sdp_settings {
      advanced_config {
        inspect_template     = "{{index $.Vars "filter_config_sdp_settings_advanced_config_inspect_template"}}"
        deidentify_template  = "{{index $.Vars "filter_config_sdp_settings_advanced_config_deidentify_template"}}"
      }
    }
  }
  template_metadata {
    multi_language_detection {
      enable_multi_language_detection = {{index $.Vars "template_metadata_multi_language_detection_enable_multi_language_detection"}}
    }
  }
}