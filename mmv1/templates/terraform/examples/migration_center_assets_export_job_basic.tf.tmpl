resource "google_migration_center_assets_export_job" "default" {
  location             = "us-central1"
  assets_export_job_id = "{{index $.Vars "assets_export_job_id"}}"
  performance_data {
    max_days = 30
  }
  show_hidden = true
  signed_uri_destination {
    file_format = "CSV"
  }
  labels = {
    key = "value"
  }
}
