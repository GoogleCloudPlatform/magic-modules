resource "google_discovery_engine_data_store" "{{$.PrimaryResourceId}}" {
  location                     = "global"
  data_store_id                = "{{index $.Vars "data_store_id"}}"
  display_name                 = "tf-test-workspace-datastore"
  industry_vertical            = "GENERIC"
  content_config               = "GOOGLE_WORKSPACE"
  solution_types               = ["SOLUTION_TYPE_SEARCH"]
  skip_default_schema_creation = false

  workspace_config {
    type = "GOOGLE_DRIVE"
  }
}
