resource "google_project_service" "geminidataanalytics" {
  provider = google-beta

  service            = "geminidataanalytics.googleapis.com"
  disable_on_destroy = false
}

resource "google_project_service" "cloudkms" {
  provider = google-beta

  service            = "cloudkms.googleapis.com"
  disable_on_destroy = false
}

data "google_project" "project" {
  provider = google-beta
}

resource "google_kms_key_ring" "key_ring" {
  provider = google-beta

  name     = "{{index $.Vars "key_ring_id"}}"
  location = "global"

  depends_on = [google_project_service.cloudkms]
}

resource "google_kms_crypto_key" "crypto_key" {
  provider = google-beta

  name     = "{{index $.Vars "crypto_key_id"}}"
  key_ring = google_kms_key_ring.key_ring.id
}

resource "google_project_iam_member" "kms_iam" {
  provider = google-beta

  project = data.google_project.project.project_id
  role    = "roles/cloudkms.cryptoKeyEncrypterDecrypter"
  member  = "serviceAccount:service-${data.google_project.project.number}@gcp-sa-geminidataanalytics.iam.gserviceaccount.com"
}

resource "google_gemini_data_analytics_data_agent" "{{$.PrimaryResourceId}}" {
  provider = google-beta

  location      = "global"
  data_agent_id = "{{index $.Vars "data_agent_id"}}"
  display_name  = "CMEK data agent"
  description   = "Example Gemini Data Analytics data agent with customer-managed encryption."

  kms_key = google_kms_crypto_key.crypto_key.id

  data_analytics_agent {
    staging_context {
      system_instruction = "Answer questions about the sample Shakespeare corpus."

      datasource_references {
        bq {
          table_references {
            project_id = "bigquery-public-data"
            dataset_id = "samples"
            table_id   = "shakespeare"
          }
        }
      }
    }
  }

  depends_on = [
    google_project_service.geminidataanalytics,
    google_project_iam_member.kms_iam,
  ]
}
