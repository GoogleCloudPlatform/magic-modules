resource "google_firebase_remote_config_remote_config" "{{$.PrimaryResourceId}}" {
  conditions {
    name       = "ios_us"
    expression = "device.os == 'ios' && device.country in ['us']"
    tag_color  = "TEAL"
  }

  conditions {
    name       = "ios_uk"
    expression = "device.os == 'ios' && device.country in ['uk']"
    tag_color  = "BLUE"
  }

  parameters {
    key = "welcome_message"
    description = "Welcome message"
    value_type  = "STRING"
    default_value {
      value = "Welcome to the App!"
    }
    conditional_values {
      condition_name = "ios_us"
      value          = "Welcome to the App on iOS!"
    }
    conditional_values {
      condition_name     = "ios_uk"
      use_in_app_default = true
    }
  }

  parameters {
    key = "welcome_message_2"
    description = "Welcome message"
    value_type  = "STRING"
    default_value {
      use_in_app_default = true
    }
  }

  parameter_groups {
    key = "group_a"
    description = "Parameter group A description"
    
    parameters {
      key = "welcome_message_group"
      description = "Welcome message"
      value_type  = "STRING"
      default_value {
        value = "Welcome to the App!"
      }
      conditional_values {
        condition_name = "ios_us"
        value          = "Welcome to the App on iOS!"
      }
      conditional_values {
        condition_name     = "ios_uk"
        use_in_app_default = true
      }
    }

    parameters {
      key = "welcome_message_group_2"
      description = "Welcome message"
      value_type  = "STRING"
      default_value {
        use_in_app_default = true
      }
    }
  }
}
