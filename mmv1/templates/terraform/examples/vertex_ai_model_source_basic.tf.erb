resource "google_vertex_ai_models" "<%= ctx[:primary_resource_id] %>" {
  display_name = "<%= ctx[:vars]['display_name'] %>"
  project = "<%= ctx[:test_env_vars]['project_name'] %>"
  source_model = "projects/<%= ctx[:test_env_vars]['project_name'] %>/locations/us-central1/models/4469245519628878651"
  description  = "sample description"
  labels       = {
    "key1" : "value1",
    "key2" : "value2"
  }
  region       = "us-central1"
  encryption_spec {
    kms_key_name = "<%= ctx[:vars]['kms_key_name'] %>"
  }
  depends_on = [google_kms_crypto_key_iam_member.crypto_key]
}