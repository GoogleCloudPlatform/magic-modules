resource "google_pubsub_topic" "topic" {
  name = "{{index $.Vars "topic_name"}}"
}

resource "google_dataplex_metadata_feed" "{{$.PrimaryResourceId}}" {
  metadata_feed_id = "{{index $.Vars "metadata_feed_id"}}"
  project = "{{index $.TestEnvVars "project_name"}}"
  location = "us-central1"
  description = "Example metadata feed updated"
  labels = {
    "item" = "2"
  }
  scope {
    projects = ["projects/{{index $.TestEnvVars "project_name"}}"]
  }
  filters {
    entry_types = ["projects/{{index $.TestEnvVars "project_name"}}/locations/us-central1/entryTypes/database"]
    aspect_types = ["projects/{{index $.TestEnvVars "project_name"}}/locations/us-central1/aspectTypes/table"]
    change_types = ["UPDATE"]
  }
  pubsub_topic = google_pubsub_topic.topic.id
}
