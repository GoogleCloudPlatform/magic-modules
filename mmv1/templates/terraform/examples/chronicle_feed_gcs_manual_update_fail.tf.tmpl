# This is a manual test example for Terraform support in Chronicle feeds APIs.
# Valid for source type: GOOGLE_CLOUD_STORAGE_EVENT_DRIVEN and GOOGLE_CLOUD_STORAGE.
# NOTE: Change the display_name to an existing display_name. This would cause the test to fail.
# This is a failing example, so a failure is the expected outcome.

terraform {
  required_providers {
    google-beta = { source = "hashicorp/google-beta" }
  }
}

provider "google-beta" {
  project = "{{index $.TestEnvVars "project_name"}}"
}

resource "google_chronicle_feed" "test_update" {
  provider = google-beta
  location = "us"
  instance = "{{index $.TestEnvVars "chronicle_id"}}"

  # This is a placeholder. Use the exact feed you want to update.
  feed     = "abcdefgh-1234-abcd-1234-abcdef123456"

  # Important: Use an existing display_name
  display_name = "test-display-name"

  details {
      feed_source_type = "GOOGLE_CLOUD_STORAGE_EVENT_DRIVEN"
      log_type         = "projects/{{index $.TestEnvVars "project_name"}}/locations/us/instances/{{index $.TestEnvVars "chronicle_id"}}/logTypes/GCP_CLOUDAUDIT"

      google_cloud_storage_event_driven_settings {
          # This is a placeholder bucket URI. Use the exact bucket URI as before or update it.
          bucket_uri          = "gs://test-bucket-uri"
          # This is a placeholder pub/sub subscription. Use the exact pub/sub subscription as before or update it.
          pubsub_subscription = "projects/{{index $.TestEnvVars "project_name"}}/subscriptions/test-pubsub-subscription"
          max_lookback_days   = 90
      }
    }
}