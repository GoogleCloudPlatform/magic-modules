resource "google_oracle_database_goldengate_deployment" "{{$.PrimaryResourceId}}" {
  goldengate_deployment_id = "{{index $.ResourceIdVars "goldengate_deployment_id"}}"
  display_name             = "{{index $.ResourceIdVars "goldengate_deployment_id"}} display name"
  location                 = "us-east4"
  project                  = "{{index $.ResourceIdVars "project"}}"
  odb_subnet               = "{{index $.ResourceIdVars "odb_subnet"}}"

  properties {
    deployment_type = "DATABASE_ORACLE"
    ogg_data {
      admin_username = "admin"
      admin_password = "123Abpassword!"
      deployment     = "deployment"
    }
  }
  deletion_policy = "{{index $.ResourceIdVars "deletion_policy"}}"
}
