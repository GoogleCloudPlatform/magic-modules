resource "google_oracle_database_autonomous_database" "{{$.PrimaryResourceId}}"{
  autonomous_database_id = "{{index $.PrefixedVars "adb_id"}}"
  location = "{{index $.PrefixedVars "location"}}"
  project = "{{index $.PrefixedVars "project"}}"
  source_config {
    autonomous_database = "{{index $.PrefixedVars "peer_adb_name"}}"
    automatic_backups_replication_enabled = "{{index $.PrefixedVars "enable_backup_replication"}}"
    }
  deletion_protection = "{{index $.PrefixedVars "deletion_protection"}}"
}
