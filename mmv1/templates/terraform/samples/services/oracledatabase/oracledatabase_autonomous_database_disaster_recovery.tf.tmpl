resource "google_oracle_database_autonomous_database" "adb-dr"{
  autonomous_database_id = "{{index $.ResourceIdVars "autonomous_database_id"}}"
  location = "us-east4"
  project = "{{index $.ResourceIdVars "project"}}"
  database = "{{index $.ResourceIdVars "database_name"}}"
  admin_password = "123Abpassword"
  properties {
    compute_count = "2"
    data_storage_size_gb="20"
    db_version = "19c"
    db_workload = "OLTP"
    license_type = "LICENSE_INCLUDED"
    mtls_connection_required = "true"
    }
  deletion_protection = "{{index $.ResourceIdVars "deletion_protection"}}"
}


resource "google_oracle_database_autonomous_database" "{{$.PrimaryResourceId}}"{
  autonomous_database_id = "{{index $.ResourceIdVars "autonomous_database_id"}}"
  location = "{{index $.ResourceIdVars "location"}}"
  project = "{{index $.ResourceIdVars "project"}}"
  source_config {
    autonomous_database = google_oracle_database_autonomous_database.adb-dr.name
    automatic_backups_replication_enabled = "{{index $.ResourceIdVars "enable_backup_replication"}}"
    }
  deletion_protection = "{{index $.ResourceIdVars "deletion_protection"}}"
}
