// Forwarding rule for External Network Load Balancing using Backend Services with IP Collection

resource "google_compute_forwarding_rule" "{{$.PrimaryResourceId}}" {
  name                  = "{{index $.ResourceIdVars "forwarding_rule_name"}}"
  region                = "us-central1"
  port_range            = 80
  ip_protocol           = "TCP"
  ip_version            = "IPV6"
  load_balancing_scheme = "EXTERNAL"
  ip_address            = "{{index $.ResourceIdVars "ip_address"}}"
  network_tier          = "PREMIUM"
  backend_service       = google_compute_region_backend_service.backend.id
  ip_collection         = "{{index $.ResourceIdVars "ip_collection_url"}}"
}

resource "google_compute_region_backend_service" "backend" {
  name                  = "{{index $.ResourceIdVars "backend_name"}}"
  region                = "us-central1"
  load_balancing_scheme = "EXTERNAL"
  health_checks         = [google_compute_region_health_check.hc.id]
}

resource "google_compute_region_health_check" "hc" {
  name               = "{{index $.ResourceIdVars "backend_name"}}"
  check_interval_sec = 1
  timeout_sec        = 1
  region             = "us-central1"

  tcp_health_check {
    port = "80"
  }
}