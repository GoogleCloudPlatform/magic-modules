resource "google_compute_region_ssl_policy" "post-quantum-region-ssl-policy" {
  name                         = "{{index $.ResourceIdVars "post_quantum_region_ssl_policy_name"}}"
  region                       = "us-central1"
  profile                      = "MODERN"
  min_tls_version              = "TLS_1_2"
  post_quantum_key_exchange    = "ENABLED"
}
