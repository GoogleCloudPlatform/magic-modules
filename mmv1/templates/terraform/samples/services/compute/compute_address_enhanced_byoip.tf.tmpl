resource "google_compute_address" "{{$.PrimaryResourceId}}" {
  name             = "{{index $.PrefixedVars "address_name"}}"
  region           = "us-central1"
  ip_collection    = google_compute_public_delegated_prefix.sub_pdp.self_link
}

resource "google_compute_public_delegated_prefix" "sub_pdp" {
  name             = "{{index $.PrefixedVars "sub_pdp_name"}}"
  region           = "us-central1"
  ip_cidr_range    = "{{index $.PrefixedVars "sub_pdp_ip_cidr"}}"
  parent_prefix    = "{{index $.PrefixedVars "root_pdp_url"}}"
}

