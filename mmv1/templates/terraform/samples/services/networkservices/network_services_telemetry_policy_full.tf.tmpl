resource "google_network_services_mesh" "default" {
  name     = "{{index $.ResourceIdVars "mesh_name"}}"
}

resource "google_network_services_telemetry_policy" "{{$.PrimaryResourceId}}" {
  name         = "{{index $.ResourceIdVars "name"}}"
  location     = "global"
  display_name = "my-telemetry-policy"

  telemetry_target {
    resources = [google_network_services_mesh.default.id]
  }

  tracing_configuration {
    sampling_rate = 0.5
    custom_span_attributes {
      attribute_name = "attribute-name"
      literal_value  = "literal-value"
    }
    parent_based_sampling {
      enabled       = true
      sampling_rate = 0.5
    }
  }

  metrics_configuration {
    enabled = true
  }

  labels = {
    foo = "bar"
  }
}
