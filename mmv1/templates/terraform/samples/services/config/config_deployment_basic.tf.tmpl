resource "google_config_deployment" "{{$.PrimaryResourceId}}" {
  name            = "{{index $.ResourceIdVars "deployment_name"}}"
  location        = "us-central1"
  service_account = "projects/{{$.ResourceIdVars.project}}/serviceAccounts/{{index $.ResourceIdVars "service_account_email"}}"

  terraform_blueprint {
    git_source {
      repo      = "https://github.com/terraform-google-modules/terraform-google-network"
      directory = "modules/vpc"
      ref       = "main"
    }
    
    input_values {
      variable_name = "project_id"
      input_value   = "{{$.ResourceIdVars.project}}"
    }
    input_values {
      variable_name = "network_name"
      input_value   = "my-network"
    }
  }
}
