resource "google_dialogflow_tool" "{{$.PrimaryResourceId}}" {
  location = "{{index $.ResourceIdVars "location"}}"
  display_name = "service-agent-tool"
  tool_key     = "service_agent_tool"
  description = "A tool with OpenAPI spec and Service Agent Auth"
  open_api_spec {
    text_schema = <<EOF
openapi: 3.0.0
info:
  title: My Tool
  version: 1.0.0
paths: {}
EOF
    authentication {
      service_agent_auth_config {
        service_agent_auth = "ID_TOKEN"
      }
    }
  }
}
