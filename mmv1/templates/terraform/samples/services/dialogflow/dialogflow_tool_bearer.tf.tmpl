resource "google_dialogflow_tool" "{{$.PrimaryResourceId}}" {
  location = "{{index $.ResourceIdVars "location"}}"
  display_name = "bearer-tool"
  tool_key     = "bearer_tool"
  description = "A tool with OpenAPI spec and Bearer Token"
  open_api_spec {
    text_schema = <<EOF
openapi: 3.0.0
info:
  title: My Tool
  version: 1.0.0
paths: {}
EOF
    authentication {
      bearer_token_config {
        token = "bearer-token"
      }
    }
  }
}
