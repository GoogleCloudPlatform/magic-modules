resource "google_dialogflow_tool" "{{$.PrimaryResourceId}}" {
  location = "{{index $.ResourceIdVars "location"}}"
  display_name = "auth-tool"
  tool_key     = "auth_tool"
  description = "A tool with OpenAPI spec and Auth"
  open_api_spec {
    text_schema = <<EOF
openapi: 3.0.0
info:
  title: My Tool
  version: 1.0.0
paths: {}
EOF
    authentication {
      api_key_config {
        key_name = "X-API-KEY"
        api_key = "secret-key"
        request_location = "HEADER"
      }
    }
  }
}
