data "google_project" "project" {}

resource "google_storage_bucket" "bucket" {
  name                        = "{{index $.ResourceIdVars "pipeline_job_id"}}"
  location                    = "us-central1"
  uniform_bucket_level_access = true
  force_destroy               = true
}

resource "google_storage_bucket_object" "notebook" {
  name    = "notebook.ipynb"
  content = "{ \"cells\": [], \"metadata\": {}, \"nbformat\": 4, \"nbminor\": 0 }"
  bucket  = google_storage_bucket.bucket.name
}

resource "google_vertex_ai_schedule" "{{$.PrimaryResourceId}}" {
  display_name             = "{{index $.Vars "display_name"}}"
  location                 = "us-central1"
  max_concurrent_run_count = {{index $.Vars "max_concurrent_run_count"}}
  cron                     = "{{index $.Vars "cron"}}"
  start_time               = "2030-01-01T00:00:00Z"

  create_notebook_execution_job_request {
    parent = "projects/${data.google_project.project.project_id}/locations/us-central1"
    notebook_execution_job {
      display_name    = "test-notebook-execution-job"
      gcs_output_uri  = "gs://${google_storage_bucket.bucket.name}"
      service_account = "${data.google_project.project.number}-compute@developer.gserviceaccount.com"
      
      gcs_notebook_source {
        uri = "gs://${google_storage_bucket.bucket.name}/${google_storage_bucket_object.notebook.name}"
      }

      custom_environment_spec {
        machine_spec {
          machine_type = "n1-standard-4"
        }
        persistent_disk_spec {
          disk_size_gb = "100"
          disk_type    = "pd-standard"
        }
      }
    }
  }
}
