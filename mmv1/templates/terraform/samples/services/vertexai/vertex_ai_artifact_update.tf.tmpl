resource "google_vertex_ai_metadata_store" "store" {
  name        = "{{index $.ResourceIdVars "storeName"}}"
  description = "Store to test Artifact"
  region      = "us-central1"
}

resource "google_vertex_ai_artifact" "{{$.PrimaryResourceId}}" {
  artifact_id    = "{{index $.ResourceIdVars "artifactId"}}"
  metadatastore  = google_vertex_ai_metadata_store.store.name
  schema_title   = "system.Dataset"
  schema_version = "0.0.1"
  uri            = "https://example.com/dataset"

  description  = "{{index $.Vars "description"}}"
  display_name = "{{index $.Vars "display_name"}}"
  
  labels = {
    label = "value"
  }

  metadata = {
    key = "value"
  }
}
