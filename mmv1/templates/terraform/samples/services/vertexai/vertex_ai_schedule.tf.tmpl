data "google_project" "project" {}

resource "google_storage_bucket" "bucket" {
  name                        = "{{index $.ResourceIdVars "pipeline_job_id"}}"
  location                    = "us-central1"
  uniform_bucket_level_access = true
  force_destroy               = true
}

resource "google_vertex_ai_schedule" "{{$.PrimaryResourceId}}" {
  display_name                    = "{{index $.Vars "display_name"}}"
  location                        = "us-central1"
  max_concurrent_run_count        = {{index $.Vars "max_concurrent_run_count"}}
  cron                            = "{{index $.Vars "cron"}}"
  allow_queueing                  = {{index $.Vars "allow_queueing"}}
  max_concurrent_active_run_count = {{index $.Vars "max_concurrent_active_run_count"}}
  max_run_count                   = "{{index $.Vars "max_run_count"}}"
  start_time                      = "2030-01-01T00:00:00Z"
  end_time                        = "{{index $.Vars "end_time"}}"

  create_pipeline_job_request {
    parent = "projects/${data.google_project.project.project_id}/locations/us-central1"
    pipeline_job {
      display_name          = "test-pipeline-job"
      preflight_validations = {{index $.Vars "preflight_validations"}}
      labels = {
        "key" = "{{index $.Vars "pipeline_job_label_value"}}"
      }
      pipeline_spec = jsonencode({
        pipelineInfo = {
          name = "hello-world"
        }
        root = {
          dag = {
            tasks = {}
          }
        }
        schemaVersion = "2.1.0"
        sdkVersion    = "kfp-2.0.0"
      })

      runtime_config {
        gcs_output_directory = "gs://${google_storage_bucket.bucket.name}/pipeline_root"
        failure_policy       = "{{index $.Vars "failure_policy"}}"
      }
    }
  }
}
