resource "google_vertex_ai_persistent_resource" "{{.PrimaryResourceId}}" {
  name         = "{{index $.ResourceIdVars "persistent_resource_id"}}"
  location     = "us-central1"
  display_name = "Example persistent resource"

  resource_pools {
    machine_spec {
      machine_type = "n1-standard-4"
    }

    replica_count = 1

    autoscaling_spec {
      min_replica_count = 1
      max_replica_count = 2
    }
}
