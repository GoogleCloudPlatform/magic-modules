resource "google_vertex_ai_reasoning_engine" "{{$.PrimaryResourceId}}" {
  display_name = "{{index $.ResourceIdVars "name"}}"
  description  = "Reasoning engine with context spec"
  region       = "us-central1"
  provider     = google-beta

  context_spec {
    memory_bank_config {
      generation_config {
        model = "projects/${data.google_project.project.project_id}/locations/us-central1/publishers/google/models/gemini-2.5-flash"
      }
      similarity_search_config {
        embedding_model = "projects/${data.google_project.project.project_id}/locations/us-central1/publishers/google/models/text-embedding-005"
      }
      disable_memory_revisions = false
      customization_configs {
        scope_keys                   = ["user_id"]
        enable_third_person_memories = false
        consolidation_config {
          revisions_per_candidate_count = 1
        }
        memory_topics {
          managed_memory_topic = "USER_PREFERENCES"
        }
      }
      structured_memory_configs {
        scope_keys = ["user_id"]
        schema_configs {
          id            = "user-profile"
          memory_schema = jsonencode({
            type = "object"
            properties = {
              technical_stack = {
                type        = "string"
                description = "Comma-separated list tools or languages used by the user."
              }
            }
          })
        }
      }
      ttl_config {
        default_ttl = "86400s"
      }
    }
  }
}

data "google_project" "project" {
  provider = google-beta
}
