resource "google_identity_platform_inbound_saml_config" "{{$.PrimaryResourceId}}" {
  name         = "{{index $.ResourceIdVars "name"}}"
  display_name = "Display Name"
  idp_config {
    idp_entity_id = "{{index $.ResourceIdVars "idp_entity_id"}}"
    sign_request  = true
    sso_url       = "https://example.com"
    idp_certificates {
      x509_certificate = file("test-fixtures/rsa_cert.pem")
    }
  }

  sp_config {
    sp_entity_id = "{{index $.ResourceIdVars "sp_entity_id"}}"
    callback_uri = "https://example.com"
  }
}
