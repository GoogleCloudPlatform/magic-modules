resource "google_database_migration_service_private_connection" "{{$.PrimaryResourceId}}" {
	display_name          = "dbms_pc"
	location              = "us-west1"
	private_connection_id = "{{index $.ResourceIdVars "private_connection_id"}}"

	labels = {
		key = "value"
	}

	psc_interface_config {
		network_attachment = resource.google_compute_network_attachment.default.id
	}

	create_without_validation = false
}

resource "google_compute_network_attachment" "default" {
  name                  = "{{index $.ResourceIdVars "attachment_name"}}"
  region                = "us-west1"
  connection_preference = "ACCEPT_AUTOMATIC"
  subnetworks           = [resource.google_compute_subnetwork.default.id]
}

resource "google_compute_network" "default" {
  name = "{{index $.ResourceIdVars "network_name"}}"
  auto_create_subnetworks = false
}

resource "google_compute_subnetwork" "default" {
  name          = "{{index $.ResourceIdVars "subnetwork_name"}}"
  ip_cidr_range = "10.0.0.0/16"
  region        = "us-west1"
  network       = google_compute_network.default.id
}
