resource "google_contact_center_insights_assessment_rule" "{{$.PrimaryResourceId}}" {
  display_name = "{{index $.ResourceIdVars "resource_name"}}"
  assessment_rule_id = "{{index $.ResourceIdVars "assessment_rule_id"}}%{id_suffix}"
  location = "us-central1"
  sample_rule {
    sample_percentage = 0.5
  }
  schedule_info {
    schedule = "every 5 minutes"
  }
  active    = true
}
