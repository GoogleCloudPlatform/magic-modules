resource "google_gke_hub_fleet" "default" {
  display_name = "my production fleet"
  default_cluster_config {
    security_posture_config {
      mode = "DISABLED"
      vulnerability_mode = "VULNERABILITY_DISABLED"
    }
    compliance_posture_config {
      mode = "ENABLED"
    }
  }
  labels = {
    env = "prod"
  }
}
