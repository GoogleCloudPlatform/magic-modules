resource "google_monitoring_custom_service" "{{$.PrimaryResourceId}}" {
  service_id = "{{index $.ResourceIdVars "service_id"}}"
  display_name = "My Custom Service {{index $.ResourceIdVars "service_id"}}"

  telemetry {
  	resource_name = "{{index $.ResourceIdVars "resource_name"}}"
  }

  user_labels = {
    my_key       = "my_value"
    my_other_key = "my_other_value"
  }
}
