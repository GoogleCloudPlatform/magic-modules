resource "google_gemini_repository_group" "example" {
  location = "us-central1"
  code_repository_index = "example-cri"
  repository_group_id = "{{index $.ResourceIdVars "repository_group_id"}}"
  repositories {
    resource = "{{index $.ResourceIdVars "repository_resource"}}"
    branch_pattern = "main"
  }
  labels = {"label1": "value1"}
}
