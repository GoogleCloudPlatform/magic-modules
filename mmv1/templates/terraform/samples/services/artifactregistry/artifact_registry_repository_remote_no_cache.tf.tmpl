resource "google_artifact_registry_repository" "{{$.PrimaryResourceId}}" {
  location      = "us-central1"
  repository_id = "{{index $.ResourceIdVars "repository_id"}}"
  description   = "{{index $.ResourceIdVars "desc"}}"
  format        = "DOCKER"
  mode          = "REMOTE_REPOSITORY"

  # Setting no_cache{} configures the Connector repository.
  remote_repository_config {
    description = "docker hub connector repository (no cache)"
    docker_repository {
      public_repository = "DOCKER_HUB"
    }
    no_cache {}
  }
}
