	// Helper to normalize IPv6 CIDRs (e.g. converting :0:0:0:0/64 to ::/64)
	normalizeCidr := func(cidrStr string) string {
		if cidrStr == "" {
			return ""
		}
		ip, ipNet, err := net.ParseCIDR(cidrStr)
		if err != nil {
			return cidrStr
		}
		maskSize, _ := ipNet.Mask.Size()
		return fmt.Sprintf("%s/%d", ip.String(), maskSize)
