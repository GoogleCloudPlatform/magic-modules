				if userCidr == "" {
					// User omitted CIDR in HCL: inherit allocated state CIDR
					if oldItem, ok := oldByName[rangeName]; ok && oldItem["ip_cidr_range"] != nil && oldItem["ip_cidr_range"] != "" {
						normalizedItem[k] = normalizeCidr(oldItem["ip_cidr_range"].(string))
					}
				} else {
					normalizedItem[k] = normalizeCidr(userCidr)
				}
				continue
			}
			if v == nil || v == "" {
				continue
			}
			if k == "ip_collection" {
				if rel, err := tpgresource.GetRelativePath(v.(string)); err == nil {
					normalizedItem[k] = rel
				} else {
					normalizedItem[k] = v
				}
			} else {
				normalizedItem[k] = v
			}
		}
		normalizedNew = append(normalizedNew, normalizedItem)
	}

	var hashFunc schema.SchemaSetFunc
	if ResourceComputeSubnetwork().Schema != nil && ResourceComputeSubnetwork().Schema["secondary_ip_range"] != nil {
