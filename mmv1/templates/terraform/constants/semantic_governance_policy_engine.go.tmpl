// Helper functions for the SemanticGovernancePolicyEngine (SGPE) resource,
// referenced from the resource YAML's custom_code.constants key.

// sgpePostReadDispatch runs after the standard Read has fetched the engine
// into `res`, but before the schema is flattened from it (per resource.go.tmpl
// ordering). The API returns 200 + INACTIVE (not 404) for a deprovisioned or
// uninitialized singleton, so this translates INACTIVE into "gone" by clearing
// the ID; every other state is left in state. A missing or non-string `state`
// is a backend contract break and returns an error.
//
// It reads `res["state"]` directly because the schema flatten has not yet
// populated d.Get("state") at this point, and accepts the minimal
// sgpeResourceID interface rather than *schema.ResourceData so unit tests can
// substitute a fake.
type sgpeResourceID interface {
	Id() string
	SetId(string)
}

func sgpePostReadDispatch(d sgpeResourceID, res map[string]interface{}) error {
	state, ok := res["state"].(string)
	if !ok {
		return fmt.Errorf("SGPE response is missing or has malformed state field; backend regression.")
	}
	// Only INACTIVE clears the ID (treat as deleted; next apply re-creates).
	// Every other state — including FAILED and any unrecognized state a newer
	// backend may add — is intentionally left in state. FAILED is a real
	// terminal state (per the SGPE API a FAILED engine may be re-provisioned
	// or deprovisioned), so we surface it via the Computed `state` attribute
	// and let the user choose to destroy (deprovision) or re-apply
	// (re-provision).
	if state == "INACTIVE" {
		log.Printf("[WARN] SemanticGovernancePolicyEngine %q is INACTIVE; treating as deleted, next apply will re-create", d.Id())
		d.SetId("")
	}
	return nil
}

// CustomizeDiff helpers wired via the YAML custom_diff list. Both
// accept tpgresource.TerraformResourceDiff so unit tests can drive
// them via tpgresource.ResourceDiffMock.

// sgpeFailedStateWarningCheck is the CustomizeDiff entry point for
// Check 1. Delegates to the testable inner func.
func sgpeFailedStateWarningCheck(_ context.Context, diff *schema.ResourceDiff, meta interface{}) error {
	return sgpeFailedStateWarningCheckFunc(diff)
}

// sgpeFailedStateWarningCheckFunc logs [WARN] and returns nil when the
// prior state is FAILED and gateway_config is changing. Never blocks
// the plan. The Plugin SDK v2 CustomizeDiff signature has no
// Diagnostics channel, so the warning surfaces only at TF_LOG=WARN.
func sgpeFailedStateWarningCheckFunc(diff tpgresource.TerraformResourceDiff) error {
	priorStateRaw, _ := diff.GetChange("state")
	priorState, ok := priorStateRaw.(string)
	if !ok || priorState != "FAILED" {
		return nil
	}
	// Explicit per-field GetChange + reflect.DeepEqual (not diff.HasChange)
	// because ResourceDiffMock's HasChange panics on slice/map values.
	before, after := diff.GetChange("gateway_config")
	if reflect.DeepEqual(before, after) {
		return nil
	}
	log.Printf("[WARN] This SemanticGovernancePolicyEngine is in FAILED state. " +
		"Applying any change will trigger a full re-provision — equivalent to a " +
		"`terraform destroy` followed by `terraform apply`. The values of " +
		"output-only fields such as `psc_service_attachment`, `ip_address`, and " +
		"`psc_forwarding_rule` are likely to change.")
	return nil
}

// extractGatewayConfigBlocks normalizes the diff's gateway_config value
// across production *schema.ResourceDiff (returns *schema.Set) and
// tpgresource.ResourceDiffMock (returns the raw slice) into a canonical
// []map[string]interface{}.
func extractGatewayConfigBlocks(raw interface{}) []map[string]interface{} {
	if raw == nil {
		return nil
	}
	switch v := raw.(type) {
	case *schema.Set:
		out := make([]map[string]interface{}, 0, v.Len())
		for _, item := range v.List() {
			if m, ok := item.(map[string]interface{}); ok {
				out = append(out, m)
			}
		}
		return out
	case []map[string]interface{}:
		return v
	default:
		return nil
	}
}

// sgpeGatewayConfigDuplicateNameCheck is the CustomizeDiff entry point
// for Check 2. Delegates to the testable inner func.
func sgpeGatewayConfigDuplicateNameCheck(_ context.Context, diff *schema.ResourceDiff, meta interface{}) error {
	return sgpeGatewayConfigDuplicateNameCheckFunc(diff)
}

// sgpeGatewayConfigDuplicateNameCheckFunc errors on the first duplicate
// `name` across planned gateway_config blocks; blocks the plan before
// the RPC fires (proto3 maps would otherwise silently overwrite server-
// side). Does not detect renames — rename is treated as a normal
// drop-then-add map delta.
func sgpeGatewayConfigDuplicateNameCheckFunc(diff tpgresource.TerraformResourceDiff) error {
	plannedRaw := diff.Get("gateway_config")
	planned := extractGatewayConfigBlocks(plannedRaw)

	seen := make(map[string]bool, len(planned))
	for _, block := range planned {
		name, _ := block["name"].(string)
		// Empty names are skipped here; the schema's Required:true on
		// the key field surfaces those during standard validation.
		if name == "" {
			continue
		}
		if seen[name] {
			return fmt.Errorf("gateway_config.name %q is duplicated; each block must have a unique name.", name)
		}
		seen[name] = true
	}
	return nil
}
