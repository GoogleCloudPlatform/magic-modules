func resourceListingDiscoveryTypeRestrictedExportDiffSuppress(_, old, new string, d *schema.ResourceData) bool {
    // Suppress if 'new' is the default private type
    // and restricted export config is actively being used.
    if new != "DISCOVERY_TYPE_PRIVATE" && new != "" {
        return false // Not suppressing if the new value isn't the default or empty
    }

    // Check if 'restricted_export_config' is set
    restrictedExportConfig, restrictedExportOk := d.GetOk("restricted_export_config")
    if !restrictedExportOk || restrictedExportConfig == nil {
        return false // No restricted_export_config, so no conflict to consider
    }

    // restricted_export_config is a TypeList with MaxItems: 1
    l := restrictedExportConfig.([]interface{})
    if len(l) == 0 || l[0] == nil {
        return false // No actual block within restricted_export_config
    }

    restrictedConfigMap := l[0].(map[string]interface{})

    // Check if 'enabled' is present and true within restricted_export_config
    // The YAML defines 'enabled' as a Boolean.
    enabledValue, enabledOk := restrictedConfigMap["enabled"]
    if !enabledOk || enabledValue == nil {
        return false // 'enabled' field not found or is nil
    }

    // Assert the type to bool
    if enabled, isBool := enabledValue.(bool); isBool {
        if enabled {
            // If 'restricted_export_config.enabled' is true, suppress the diff for discovery_type.
            return true
        }
    }

    return false // No condition met for suppression
}